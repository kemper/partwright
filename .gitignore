# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude Code worktrees
.claude/worktrees/

# Playwright MCP artifacts
.playwright-mcp/

# Playwright test runner output
test-results/
playwright-report/
playwright/.cache/

# scripts/snap.mjs temp specs (deleted after each run; ignored as a safety net)
/tests/_snap-*.spec.ts

# Interstitial planning files
.plans/

# Environment files — may contain API keys; never commit
.env
.env.*
!.env.example

# Top-level screenshots/images from testing
/*.png
/*.jpg
/*.jpeg

# Catalog debug scratch — single-catalog-entry.cjs writes here when an agent
# iterates with a temporary id like "test-foo". Real entries don't use the
# test_ prefix.
/public/catalog/test_*.partwright.json

# Build-time content-hashed catalog thumbnails — emitted by the prerender
# plugin's buildStart from each entry's stored data-URL thumbnail. Generated,
# never hand-edited.
/public/catalog/thumbs/
# Local bake side-artifact from build-catalog-entry.cjs — the real thumbnail is
# the data-URL embedded in the entry's .partwright.json, so this PNG is never
# committed.
/public/catalog/*.thumb.png

# partwright CLI daemon state (pid/ports, logs, persistent Chromium profile)
.partwright/

# Serena MCP project metadata/cache
.serena/

# Local Cloudflare/wrangler emulation cache
.wrangler/

# Figure-eval per-run output (renders, contact sheets) — keep cases/ + baseline.json
evals/figures/results/
evals/figures/cases/*/verdict.json
