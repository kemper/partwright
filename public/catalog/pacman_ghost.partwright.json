      "index": 1,
      "code": "const { Manifold, CrossSection, label } = api;\n\n// =============================================\n// PAC-MAN: sphere with wedge mouth cut out\n// Centered at x=-14, facing -Y\n// =============================================\nconst PAC_R = 9;\nconst PAC_X = -14;\n\nconst pacSphere = Manifold.sphere(PAC_R).translate([PAC_X, 0, 0]);\n\n// Mouth wedge: triangle in XY plane extruded along Z\n// Apex at (PAC_X, 0), opens toward -Y with 35-deg half-angle\nconst mouthHalfAngle = 35 * Math.PI / 180;\nconst mouthReach = PAC_R + 2;\nconst wa = mouthReach * Math.sin(mouthHalfAngle);\n\nconst mouthProfile = [\n  [PAC_X, 0],\n  [PAC_X - wa, -mouthReach],\n  [PAC_X + wa, -mouthReach]\n];\nconst mouthCS = CrossSection.ofPolygons([mouthProfile]);\nconst mouthWedge = Manifold.extrude(mouthCS, PAC_R * 2 + 4)\n  .translate([0, 0, -(PAC_R + 2)]);\n\nconst pacman = label(pacSphere.subtract(mouthWedge), 'pacman');\n\n// =============================================\n// GHOST: capsule body + scalloped feet + eyes + pupils\n// Centered at x=+14\n// =============================================\nconst GH_X = 14;\nconst GH_R = 7.5;\nconst GH_CYL_H = 8;\n\n// Hemisphere top: sphere centered at [GH_X, 0, GH_R], spans z=0..2*GH_R=0..15\nconst ghostHemi = Manifold.sphere(GH_R).translate([GH_X, 0, GH_R]);\n\n// Cylinder: from z=-GH_CYL_H to z=GH_R (top at z=7.5, overlaps hemi by 7.5 units)\nconst ghostCyl = Manifold.cylinder(GH_R + GH_CYL_H, GH_R, GH_R)\n  .translate([GH_X, 0, -GH_CYL_H]);\n\n// Scalloped feet: 3 cylinder subtractions from the bottom\nconst footR = GH_R / 3.2;\nconst numFeet = 3;\nconst scallops = [];\nfor (let i = 0; i < numFeet; i++) {\n  const angle = (i / numFeet) * 2 * Math.PI + Math.PI / 2;\n  const fx = GH_X + Math.cos(angle) * (GH_R - footR + 0.5);\n  const fy = Math.sin(angle) * (GH_R - footR + 0.5);\n  const scallop = Manifold.cylinder(4.5, footR, footR)\n    .translate([fx, fy, -GH_CYL_H - 0.5]);\n  scallops.push(scallop);\n}\nconst ghostBodyBase = ghostHemi.add(ghostCyl).subtract(Manifold.union(scallops));\n\n// Eyes: two spheres protruding from the front (-Y) face of the ghost body\n// They sit mostly outside but overlap so they connect to the body\nconst eyeZ = GH_R * 0.25; // z height (slightly above center)\nconst eyeOffX = GH_R * 0.38; // horizontal separation\nconst eyeR = 2.2;\nconst eyeEmbed = -(GH_R - eyeR * 0.5 + 0.5); // mostly protruding, ~0.8 unit overlap\n\nconst eyeShapeL = Manifold.sphere(eyeR).translate([GH_X - eyeOffX, eyeEmbed, eyeZ]);\nconst eyeShapeR = Manifold.sphere(eyeR).translate([GH_X + eyeOffX, eyeEmbed, eyeZ]);\n\n// Pupils: smaller spheres on each eye, sitting proud of the eye front (-Y)\nconst pupilR = 0.9;\nconst pupilShapeL = Manifold.sphere(pupilR)\n  .translate([GH_X - eyeOffX, eyeEmbed - eyeR * 0.5, eyeZ]);\nconst pupilShapeR = Manifold.sphere(pupilR)\n  .translate([GH_X + eyeOffX, eyeEmbed - eyeR * 0.5, eyeZ]);\n\n// Build labeled ghost: body + eyes (eyes overlap body, connecting them)\n// Pupils overlap eyes, connecting them\nconst ghostWithEyes = label(ghostBodyBase, 'ghost')\n  .add(label(eyeShapeL.add(eyeShapeR), 'eyes'))\n  .add(label(pupilShapeL.add(pupilShapeR), 'pupils'));\n\n// =============================================\n// SHARED BASE PLINTH: joins Pac-Man + ghost into ONE\n// watertight solid that sits flat on the print bed.\n// Stadium (rounded-rectangle) slab = hull of two disks,\n// one centered under each figure. Top at z=-7 so it\n// overlaps solid material of both (Pac-Man sphere cap to\n// z=-7 ~= 1.13r wide; ghost rim by ~1 unit) while leaving\n// the ghost's scalloped feet (notches reach up to z=-4)\n// clearly readable above the plinth.\n// =============================================\nconst BASE_TOP = -7;\nconst BASE_BOT = -9.5;\nconst BASE_H = BASE_TOP - BASE_BOT; // 2.5\nconst baseDiskR = 9.5;\n\nconst baseDiskPac = Manifold.cylinder(BASE_H, baseDiskR, baseDiskR)\n  .translate([PAC_X, 0, BASE_BOT]);\nconst baseDiskGhost = Manifold.cylinder(BASE_H, baseDiskR, baseDiskR)\n  .translate([GH_X, 0, BASE_BOT]);\nconst plinth = label(baseDiskPac.add(baseDiskGhost).hull(), 'base');\n\nreturn pacman.add(ghostWithEyes).add(plinth);\n",
