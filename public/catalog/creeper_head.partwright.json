      "index": 1,
      "code": "const { Manifold, label } = api;\n\n// Axis-aligned box from min..max corner.\nfunction box(min, max) {\n  const s = [max[0] - min[0], max[1] - min[1], max[2] - min[2]];\n  const c = [(min[0] + max[0]) / 2, (min[1] + max[1]) / 2, (min[2] + max[2]) / 2];\n  return Manifold.cube(s, true).translate(c);\n}\n\n// 16mm cube head, front face at y = +8.\nconst head = Manifold.cube([16, 16, 16], true);\n\n// Face features are thin raised relief on the FRONT face. The app's\n// default camera looks at the -Y / -X corner, so -Y is \"front\": features\n// sit at y -8.5..-7.5, overlapping the head body by 0.5 for a clean union.\nconst fy = [-8.5, -7.5];\n\nfunction plate(x0, x1, z0, z1) { return box([x0, fy[0], z0], [x1, fy[1], z1]); }\n\n// Eyes: two 4x4 squares.\nconst eyes = plate(-6, -2, 2, 6).add(plate(2, 6, 2, 6));\n\n// Classic creeper frown.\nconst mouth = plate(-2, 2, 0, 2) // top center\n  .add(plate(-4, 4, -4, 0)) // wide middle\n  .add(plate(-4, -2, -6, -4)) // left foot\n  .add(plate(2, 4, -6, -4)); // right foot\n\nreturn label(head, 'head')\n  .add(label(eyes, 'eyes'))\n  .add(label(mouth, 'mouth'));\n",
