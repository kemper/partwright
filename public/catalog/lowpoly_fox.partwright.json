  "versions": [
    {
      "index": 1,
      "code": "const { Manifold, label } = api;\n\n// Helper: axis-aligned box from min..max\nfunction box(min, max) {\n  const s = [max[0] - min[0], max[1] - min[1], max[2] - min[2]];\n  const c = [(min[0] + max[0]) / 2, (min[1] + max[1]) / 2, (min[2] + max[2]) / 2];\n  return Manifold.cube(s, true).translate(c);\n}\n\n// Helper: hull of two boxes (creates a wedge/tapered shape)\nfunction taperBox(x0, x1, y0, y1, z0, z1, tx0, tx1, ty0, ty1) {\n  const pts = [\n    [x0, y0, z0],\n    [x1, y0, z0],\n    [x0, y1, z0],\n    [x1, y1, z0],\n    [tx0, ty0, z1],\n    [tx1, ty0, z1],\n    [tx0, ty1, z1],\n    [tx1, ty1, z1],\n  ];\n  const spheres = pts.map(p => Manifold.sphere(0.01, 4).translate(p));\n  return Manifold.hull(spheres);\n}\n\n// Body: main torso box, sitting pose\nconst body = label(box([-5, -8, 4], [5, 4, 11]), 'body');\n\n// Chest/belly white patch (front lower area, overlapping body)\nconst chest = label(box([-3.5, -8.1, 4], [3.5, -4, 9]), 'chest');\n\n// Head: slightly wider cube, sitting on top of body\nconst head = label(box([-4.5, -7, 10.5], [4.5, 2, 16.5]), 'head');\n\n// Snout: rectangular wedge pointing forward (-Y direction)\nconst snout = label(box([-2.5, -9.5, 11], [2.5, -6.5, 14]), 'snout');\n\n// Snout tip (white): front face of snout\nconst snoutTip = label(box([-2, -9.8, 11.5], [2, -9, 13.5]), 'snoutTip');\n\n// Nose: dark nub on snout top-front\nconst nose = label(box([-1, -9.9, 13.2], [1, -9.2, 14.2]), 'nose');\n\n// Ears: triangular prisms (hull of points)\n// Left ear (-X side)\nconst leftEarPts = [\n  [-4.5, -5, 16.5],\n  [-4.5, -1, 16.5],\n  [-4.5, -5, 16.5],\n  [-2, -3, 20],\n  [-6.5, -5, 16.5],\n  [-6.5, -1, 16.5],\n  [-4, -3, 20],\n];\nconst leftEarSpheres = leftEarPts.map(p => Manifold.sphere(0.01, 4).translate(p));\nconst leftEar = label(Manifold.hull(leftEarSpheres), 'earLeft');\n\n// Right ear (+X side)\nconst rightEarPts = [\n  [4.5, -5, 16.5],\n  [4.5, -1, 16.5],\n  [2, -3, 20],\n  [6.5, -5, 16.5],\n  [6.5, -1, 16.5],\n  [4, -3, 20],\n];\nconst rightEarSpheres = rightEarPts.map(p => Manifold.sphere(0.01, 4).translate(p));\nconst rightEar = label(Manifold.hull(rightEarSpheres), 'earRight');\n\n// Ear tips (dark inner): slightly inset wedge inside each ear\nconst leftEarTipPts = [\n  [-4.5, -4, 16.5],\n  [-4.5, -2, 16.5],\n  [-6.5, -4, 16.5],\n  [-6.5, -2, 16.5],\n  [-4.5, -3, 19],\n  [-5.5, -3, 19],\n];\nconst leftEarTipSpheres = leftEarTipPts.map(p => Manifold.sphere(0.01, 4).translate(p));\nconst leftEarTip = label(Manifold.hull(leftEarTipSpheres), 'earTipLeft');\n\nconst rightEarTipPts = [\n  [4.5, -4, 16.5],\n  [4.5, -2, 16.5],\n  [6.5, -4, 16.5],\n  [6.5, -2, 16.5],\n  [4.5, -3, 19],\n  [5.5, -3, 19],\n];\nconst rightEarTipSpheres = rightEarTipPts.map(p => Manifold.sphere(0.01, 4).translate(p));\nconst rightEarTip = label(Manifold.hull(rightEarTipSpheres), 'earTipRight');\n\n// Legs: 4 short cylinders\nconst legFL = label(box([-4.5, -7.5, 0], [-2, -5, 4.5]), 'legFront');\nconst legFR = label(box([2, -7.5, 0], [4.5, -5, 4.5]), 'legFront');\nconst legBL = label(box([-4.5, 1, 0], [-2, 3.5, 4.5]), 'legBack');\nconst legBR = label(box([2, 1, 0], [4.5, 3.5, 4.5]), 'legBack');\n\n// Leg socks (dark lower portion)\nconst sockFL = label(box([-4.5, -7.5, 0], [-2, -5, 2]), 'sock');\nconst sockFR = label(box([2, -7.5, 0], [4.5, -5, 2]), 'sock');\nconst sockBL = label(box([-4.5, 1, 0], [-2, 3.5, 2]), 'sock');\nconst sockBR = label(box([2, 1, 0], [4.5, 3.5, 2]), 'sock');\n\n// Tail: large bushy tapered shape sweeping up and behind (+Y side)\n// Base at body rear, sweeping up\nconst tailBasePts = [\n  [-4, 4, 5],\n  [-4, 4, 9],\n  [4, 4, 5],\n  [4, 4, 9],\n  [-2.5, 10, 6],\n  [-2.5, 10, 10],\n  [2.5, 10, 6],\n  [2.5, 10, 10],\n];\nconst tailBaseSpheres = tailBasePts.map(p => Manifold.sphere(0.01, 4).translate(p));\nconst tailBase = Manifold.hull(tailBaseSpheres);\n\n// Tail upper portion tapering\nconst tailTopPts = [\n  [-2, 8, 9],\n  [2, 8, 9],\n  [-2, 10, 9],\n  [2, 10, 9],\n  [-1, 8, 15],\n  [1, 8, 15],\n  [-1, 10, 15],\n  [1, 10, 15],\n];\nconst tailTopSpheres = tailTopPts.map(p => Manifold.sphere(0.01, 4).translate(p));\nconst tailTop = Manifold.hull(tailTopSpheres);\n\nconst tailShape = label(tailBase.add(tailTop), 'tail');\n\n// Tail tip (white)\nconst tailTipPts = [\n  [-1, 8, 13],\n  [1, 8, 13],\n  [-1, 10, 13],\n  [1, 10, 13],\n  [0, 9, 15.5],\n];\nconst tailTipSpheres = tailTipPts.map(p => Manifold.sphere(0.01, 4).translate(p));\nconst tailTip = label(Manifold.hull(tailTipSpheres), 'tailTip');\n\n// Assemble everything - all parts overlap body by 0.5+ units\nreturn body\n  .add(chest)\n  .add(head)\n  .add(snout)\n  .add(snoutTip)\n  .add(nose)\n  .add(leftEar)\n  .add(rightEar)\n  .add(leftEarTip)\n  .add(rightEarTip)\n  .add(legFL).add(legFR).add(legBL).add(legBR)\n  .add(sockFL).add(sockFR).add(sockBL).add(sockBR)\n  .add(tailShape)\n  .add(tailTip);\n",
