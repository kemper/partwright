      "index": 1,
      "code": "const { Manifold, CrossSection, label } = api;\n\n// Main tower body: cylinder r=7, h=26, centered at origin bottom at z=0\nconst towerBody = Manifold.cylinder(26, 7, 7);\n\n// Parapet ring at top (z=24..28), slightly wider r=7.5\nconst parapetRing = Manifold.cylinder(4, 7.5, 7.5).translate([0, 0, 24]);\n\n// Crenellations: cut rectangular notches from parapet top — 8 gaps\nconst numCrenels = 8;\nconst crenelW = 1.4;\nconst crenelH = 2.5;\nconst crenelZ = 25.5;\nconst radialInner = 3.0;\nconst radialOuter = 9.0;\n\nlet crenelCuts = [];\nfor (let i = 0; i < numCrenels; i++) {\n  const angle = (i * 360) / numCrenels;\n  const block = Manifold.cube([radialOuter - radialInner, crenelW, crenelH + 0.2])\n    .translate([radialInner, -crenelW / 2, crenelZ - 0.1])\n    .rotate([0, 0, angle]);\n  crenelCuts.push(block);\n}\nconst crenelUnion = Manifold.union(crenelCuts);\nconst stoneParts = towerBody.add(parapetRing).subtract(crenelUnion);\n\n// Door opening on -Y face: arched recess carved into tower wall\n// Dark door plate: placed behind front wall surface, overlapping 2 units into stone wall\n// Extends from outside of tower inward for guaranteed union\nconst doorPlate = Manifold.cube([2.6, 2.5, 5.0]).translate([-1.3, -8.5, 0.1]);\n// Arch cap — cylinder pressed into the wall\nconst archCap = Manifold.cylinder(2.5, 1.3, 1.3).rotate([90, 0, 0]).translate([0, -8.5, 5.0]);\nconst doorFeature = doorPlate.add(archCap);\n\n// Window recesses — thin dark plates extending from outer surface inward\nconst win1 = Manifold.cube([1.6, 2.5, 2.6]).translate([-0.8, -8.5, 10.0]);\nconst win2 = Manifold.cube([1.6, 2.5, 2.6]).translate([-0.8, -8.5, 16.0]);\n\n// Conical roof: cone from r=6 at z=27 to tip at z=38\nconst roofCone = Manifold.cylinder(11, 6, 0).translate([0, 0, 27]);\n\n// Base disk wider than body for stability\nconst base = Manifold.cylinder(1.0, 8.5, 8.5);\n\nconst stone = label(stoneParts.add(base), 'stone');\nconst roof = label(roofCone, 'roof');\nconst door = label(doorFeature, 'door');\nconst windows = label(win1.add(win2), 'windows');\n\nreturn stone.add(roof).add(door).add(windows);\n",
