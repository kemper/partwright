      "index": 1,
      "code": "// Castle Tower — grand medieval stone tower with voronoi stone texture\n// Z-up, tower centered at X=0 Y=0, base at Z=0\n// Total height: ~44mm (base 2 + tower 27 + parapet 3 + merlons 3 + roof 11)\n\nconst { Manifold, CrossSection } = api;\n\n// === DIMENSIONS ===\nconst towerR       = 9.0;    // main tower radius\nconst baseR        = 11.0;   // battered base ring radius\nconst baseH        = 2.0;    // base ring height\nconst towerH       = 27.0;   // tower body height (above base)\nconst parapetR     = 9.8;    // parapet ring slightly wider\nconst parapetH     = 2.5;    // parapet ring height (slightly taller)\nconst parapetZ     = baseH + towerH;\nconst merlonH      = 3.2;    // merlon height above parapet top (taller for prominence)\nconst roofBaseR    = 8.8;    // cone base fits INSIDE the parapet ring\nconst roofZ        = parapetZ + parapetH - 0.2;\nconst roofH        = 11.5;   // cone height\n\n// === BASE (battered, wider at bottom) ===\nconst base = Manifold.cylinder(baseH, baseR, towerR + 0.3, 64);\n\n// === TOWER BODY (slight taper) ===\nconst towerBody = Manifold.cylinder(towerH + 0.5, towerR, towerR - 0.5, 64)\n  .translate([0, 0, baseH - 0.5]);\n\n// === PARAPET RING ===\nconst parapetRing = Manifold.cylinder(parapetH, parapetR, parapetR, 64)\n  .translate([0, 0, parapetZ]);\n\n// === CRENELLATIONS — 8 merlons ===\n// Each merlon: a thick block placed radially at the parapet top.\n// The block's radial (depth) dimension spans the full parapet thickness plus a bit extra.\n// Its tangential width is ~50% of the sector arc length.\nconst numMerlons    = 8;\nconst sectorAng     = 360 / numMerlons;   // 45°\nconst merlonArcFrac = 0.50;               // merlon uses 50% of arc\nconst merlonZ       = parapetZ + parapetH;\n\n// Arc chord length at parapetR\nconst arcLen        = 2 * Math.PI * parapetR * (merlonArcFrac / numMerlons);\nconst merlonWidth   = arcLen;             // tangential size\nconst merlonDepth   = 2.8;               // radial size\nconst merlonCenterR = parapetR - merlonDepth / 2 + 0.4;  // radial placement\n\nlet merlons = [];\nfor (let i = 0; i < numMerlons; i++) {\n  const angle = i * sectorAng;\n  // Box: depth × width × height, centered on the parapet ring perimeter\n  const merlon = Manifold.cube([merlonDepth + 0.6, merlonWidth, merlonH + 0.5])\n    .translate([\n      merlonCenterR - (merlonDepth + 0.6) / 2,\n      -merlonWidth / 2,\n      merlonZ - 0.5  // overlap 0.5 into parapet top for guaranteed union\n    ])\n    .rotate([0, 0, angle]);\n  merlons.push(merlon);\n}\nconst allMerlons = Manifold.union(merlons);\n\n// === STONE BODY ===\nconst stoneSolid = Manifold.union([base, towerBody, parapetRing, allMerlons]);\n\n// === DOOR — Gothic arch on -Y face ===\nconst doorW  = 3.4;\nconst doorH  = 6.0;\nconst archR  = doorW / 2;\n\nconst doorRect  = CrossSection.square([doorW, doorH - archR])\n  .translate([-doorW / 2, 0]);\nconst doorArc   = CrossSection.circle(archR, 24).translate([0, doorH - archR]);\nconst doorShape = CrossSection.union([doorRect, doorArc]);\n\n// Extrude well past wall to punch clean through\nconst doorCutter = Manifold.extrude(doorShape, 6.0)\n  .rotate([90, 0, 0])\n  .translate([0, -towerR - 2.5, baseH + 0.5]);\n\n// Door frame: arch molding on the outside of the tower\n// Starts inside tower surface so it boolean-unions correctly\nconst frameW  = doorW + 1.6;\nconst frameH  = doorH + 1.0;\nconst frameR  = frameW / 2;\nconst frameRect2 = CrossSection.square([frameW, frameH - frameR])\n  .translate([-frameW / 2, 0]);\nconst frameArc2  = CrossSection.circle(frameR, 24).translate([0, frameH - frameR]);\nconst frameShape = CrossSection.union([frameRect2, frameArc2]);\n\n// depth 2.0mm: starts 1.0mm inside surface, protrudes 1.0mm outward\nconst doorFrame = Manifold.extrude(frameShape, 2.0)\n  .rotate([90, 0, 0])\n  .translate([0, -(towerR - 1.0), baseH + 0.3]);\n\n// === ARROW SLIT WINDOWS — 3 narrow vertical slots ===\nconst slitW = 0.9;\nconst slitH = 4.2;\nconst slitD = 5.5;  // more than 2×wall thickness to ensure clean cut\n\nfunction makeSlitCutter(zCenter, angle) {\n  return Manifold.cube([slitW, slitD, slitH])\n    .translate([-slitW / 2, -towerR - 2.0, zCenter - slitH / 2])\n    .rotate([0, 0, angle]);\n}\n\n// 3 windows at distinct angles (away from door at 0°)\nconst slit1 = makeSlitCutter(baseH + 9.0,   72);\nconst slit2 = makeSlitCutter(baseH + 17.5, -72);\nconst slit3 = makeSlitCutter(baseH + 24.0,  135);\nconst allSlits = Manifold.union([slit1, slit2, slit3]);\n\n// Arrow slit frames: thin raised border around each slit\n// The frame is a slightly wider/taller cube, shallower protrusion\n// It starts 1.5mm INSIDE the tower surface so it's always fused\nfunction makeSlitFrame(zCenter, angle) {\n  const fw = slitW + 1.6;   // slightly wider than slit\n  const fh = slitH + 1.6;   // slightly taller than slit\n  const fd = 1.4;           // thin — only 0.4mm protrusion beyond surface (1.4 - 1.0 inside)\n  const frameInner = towerR - 1.0;  // inner edge is 1.0mm inside tower surface\n  return Manifold.cube([fw, fd, fh])\n    .translate([-fw / 2, -(frameInner + fd), zCenter - fh / 2])\n    .rotate([0, 0, angle]);\n}\n\nconst frame1 = makeSlitFrame(baseH + 9.0,   72);\nconst frame2 = makeSlitFrame(baseH + 17.5, -72);\nconst frame3 = makeSlitFrame(baseH + 24.0,  135);\nconst allSlitFrames = Manifold.union([frame1, frame2, frame3]);\n\n// Union frames into stone body FIRST, then cut openings\nconst stoneWithFrames   = Manifold.union([stoneSolid, allSlitFrames]);\nconst stoneWithOpenings = stoneWithFrames\n  .subtract(doorCutter)\n  .subtract(allSlits);\n\n// === CONICAL ROOF ===\n// The roof fits inside the parapet ring top — merlons rise above the roof base\nconst roofCone = Manifold.cylinder(roofH, roofBaseR, 0.15, 64)\n  .translate([0, 0, roofZ]);\n\n// === LABEL PARTS ===\nconst stoneLabeled = api.label(stoneWithOpenings, 'stone',    { color: '#8a8a8a' });\nconst roofLabeled  = api.label(roofCone,          'roof',     { color: '#1e3a7a' });\nconst frameLabeled = api.label(doorFrame,         'woodwork', { color: '#3d2610' });\n\n// === ASSEMBLE ===\nconst assembled = Manifold.union([stoneLabeled, roofLabeled, frameLabeled]);\n\n// === VORONOI STONE TEXTURE ===\napi.surface.voronoi({\n  amplitude: 0.52,\n  cellSize: 7,\n  wallWidth: 0.55,\n  jitter: 0.65,\n  quality: 0.5,\n  label: 'stone'\n});\n\nreturn assembled;\n",
