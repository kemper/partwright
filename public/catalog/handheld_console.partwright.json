      "code": "const { Manifold, label, setCircularSegments } = api;\nsetCircularSegments(32);\n\nfunction box(min, max) {\n  const s = [max[0] - min[0], max[1] - min[1], max[2] - min[2]];\n  const c = [(min[0] + max[0]) / 2, (min[1] + max[1]) / 2, (min[2] + max[2]) / 2];\n  return Manifold.cube(s, true).translate(c);\n}\n\n// Body: 16w x 26h x 5d, front face at y=-2.5\nconst body = box([-8, -2.5, -13], [8, 2.5, 13]);\n\n// Protrusions — all go from y=-3 (front) to y=-1 (1.5 units into body)\nconst Yf = -3.0;\nconst Yb = -1.0;\n\n// Screen bezel\nconst bezel = box([-5.5, Yf, 2.0], [5.5, Yb, 11.5]);\n\n// Screen inside bezel\nconst screen = box([-4.5, Yf - 0.1, 2.8], [4.5, Yb, 10.8]);\n\n// D-pad: horizontal + vertical bars (wider union piece)\nconst dpadH = box([-7.5, Yf, -5.5], [-3.5, Yb, -3.8]);\nconst dpadV = box([-6.25, Yf, -6.8], [-4.75, Yb, -2.5]);\n\n// Action buttons: use rectangular bumps that clearly overlap body\nconst btnA = box([4.5, Yf, -5.0], [6.5, Yb, -3.0]);\nconst btnB = box([2.8, Yf, -6.8], [4.8, Yb, -4.8]);\n\n// Start / Select\nconst startBtn = box([-1.8, Yf, -8.2], [-0.5, Yb, -7.5]);\nconst selectBtn = box([0.2, Yf, -8.2], [1.5, Yb, -7.5]);\n\n// Speaker grille: 4 horizontal lines — made thick enough to union\nconst sp1 = box([3.0, Yf, -8.8], [7.5, Yb, -8.3]);\nconst sp2 = box([3.0, Yf, -9.5], [7.5, Yb, -9.0]);\nconst sp3 = box([3.0, Yf, -10.2], [7.5, Yb, -9.7]);\nconst sp4 = box([3.0, Yf, -10.9], [7.5, Yb, -10.4]);\n\n// Build the full geometry as one Manifold union (no labels = 1 component)\nconst allFeatures = bezel.add(screen).add(dpadH).add(dpadV)\n  .add(btnA).add(btnB)\n  .add(startBtn).add(selectBtn)\n  .add(sp1).add(sp2).add(sp3).add(sp4);\n\nconst fullBody = label(body.add(allFeatures), 'body');\n\n// Now label specific surface regions by re-creating labeled overlapping shapes\n// The labeled shapes overlap the full mesh — paintByLabels resolves by triangle provenance\nconst bezelL = label(bezel, 'bezel');\nconst screenL = label(screen, 'screen');\nconst dpadL = label(dpadH.add(dpadV), 'dpad');\nconst btnL = label(btnA.add(btnB), 'buttons');\nconst ssL = label(startBtn.add(selectBtn), 'startselect');\nconst spL = label(sp1.add(sp2).add(sp3).add(sp4), 'speaker');\n\nreturn fullBody.add(bezelL).add(screenL).add(dpadL).add(btnL).add(ssL).add(spL);\n",
