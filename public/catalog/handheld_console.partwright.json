      "index": 1,
      "code": "const { Manifold, label, setCircularSegments } = api;\nsetCircularSegments(48);\n\nfunction box(min, max) {\n  const s = [max[0] - min[0], max[1] - min[1], max[2] - min[2]];\n  const c = [(min[0] + max[0]) / 2, (min[1] + max[1]) / 2, (min[2] + max[2]) / 2];\n  return Manifold.cube(s, true).translate(c);\n}\n\n// Front face normal is -Y. A Z-axis cylinder rotated [90,0,0] points its axis\n// along -Y, so its circular face lies in the XZ plane and reads as a CIRCLE\n// from the front.\nfunction roundBtn(cx, cz, r, backY, depth) {\n  return Manifold.cylinder(depth, r, r) // along +Z, z in [0, depth]\n    .rotate([90, 0, 0]) // axis -> -Y; spans y in [-depth, 0]\n    .translate([cx, backY, cz]); // back face at y=backY, front proud at backY-depth\n}\n\n// A rounded \"pill\" (stadium): hull of two coaxial Y-axis discs.\nfunction pillBtn(cx, cz, halfLen, r, backY, depth) {\n  const a = roundBtn(-halfLen, 0, r, backY, depth);\n  const b = roundBtn(+halfLen, 0, r, backY, depth);\n  return a.add(b).hull().translate([cx, 0, cz]);\n}\n\n// Body: 16w x 26h x 5d, front face at y=-2.5\nconst body = box([-8, -2.5, -13], [8, 2.5, 13]);\n\nconst Yf = -3.0;\nconst Yb = -1.0;\n\nconst btnBackY = -1.0;\nconst btnDepth = 2.4;\n\n// Screen bezel + green screen\nconst bezel = box([-5.5, Yf, 2.0], [5.5, Yb, 11.5]);\nconst screen = box([-4.5, Yf - 0.1, 2.8], [4.5, Yb, 10.8]);\n\n// D-pad: PLUS cross (kept)\nconst dpadH = box([-7.5, Yf, -5.5], [-3.5, Yb, -3.8]);\nconst dpadV = box([-6.25, Yf, -6.8], [-4.75, Yb, -2.5]);\n\n// A / B action buttons: ROUND raised discs, placed DIAGONALLY.\nconst btnR = 1.4;\nconst btnB = roundBtn(3.6, -5.9, btnR, btnBackY, btnDepth); // lower-left\nconst btnA = roundBtn(6.1, -4.2, btnR, btnBackY, btnDepth); // upper-right\n\n// Start / Select: two small rounded pills, angled slightly, near center-bottom.\nconst ssDepth = 1.9;\nconst ssBackY = -1.0;\nconst startBtn = pillBtn(-1.5, -8.4, 0.55, 0.5, ssBackY, ssDepth);\nconst selectBtn = pillBtn(1.5, -8.4, 0.55, 0.5, ssBackY, ssDepth);\nconst startSel = startBtn.add(selectBtn).rotate([0, -22, 0]);\n\n// Speaker grille: diagonal slots, lower-right.\nfunction slot(cx, cz, len) {\n  return box([-len / 2, Yf, -0.27], [len / 2, Yb, 0.27])\n    .rotate([0, -32, 0])\n    .translate([cx, 0, cz]);\n}\nconst sp1 = slot(5.2, -8.7, 4.0);\nconst sp2 = slot(5.2, -9.5, 4.0);\nconst sp3 = slot(5.2, -10.3, 4.0);\nconst sp4 = slot(5.2, -11.1, 4.0);\n\nconst allFeatures = bezel.add(screen).add(dpadH).add(dpadV)\n  .add(btnA).add(btnB)\n  .add(startSel)\n  .add(sp1).add(sp2).add(sp3).add(sp4);\n\nconst fullBody = label(body.add(allFeatures), 'body');\n\nconst bezelL = label(bezel, 'bezel');\nconst screenL = label(screen, 'screen');\nconst dpadL = label(dpadH.add(dpadV), 'dpad');\nconst btnAL = label(btnA, 'btnA');\nconst btnBL = label(btnB, 'btnB');\nconst ssL = label(startSel, 'startselect');\nconst spL = label(sp1.add(sp2).add(sp3).add(sp4), 'speaker');\n\nreturn fullBody.add(bezelL).add(screenL).add(dpadL)\n  .add(btnAL).add(btnBL).add(ssL).add(spL);\n",
