      "index": 1,
      "code": "// Classic 1989 gray-brick handheld likeness — generic, no brand text/logos.\n// Body is an exact convex hull of corner spheres (Manifold.compose(...).hull()),\n// with a visibly larger radius at the bottom-right corner (the iconic\n// asymmetric curve). All face features are recessed (subtracted from the\n// body) and/or proud (added in front), then re-labeled with duplicate\n// overlapping volumes so paint targets the right triangles.\nconst __pwModel = (() => {\nconst { Manifold, label } = api;\n\nfunction box(min, max) {\n  const s = [max[0] - min[0], max[1] - min[1], max[2] - min[2]];\n  const c = [(min[0] + max[0]) / 2, (min[1] + max[1]) / 2, (min[2] + max[2]) / 2];\n  return Manifold.cube(s, true).translate(c);\n}\n\nfunction hullOf(parts) {\n  return Manifold.compose(parts).hull();\n}\n\n// Front face normal is -Y. A Z-axis cylinder rotated [90,0,0] points its axis\n// along -Y, so its circular face lies in the XZ plane and reads as a CIRCLE\n// from the front. `backY` is the non-proud (embedded) end; the proud tip\n// sits at y = backY - depth (more negative = further toward the camera).\nfunction roundBtn(cx, cz, r, backY, depth, segments = 40) {\n  return Manifold.cylinder(depth, r, r, segments)\n    .rotate([90, 0, 0])\n    .translate([cx, backY, cz]);\n}\n\n// A rounded \"pill\" (stadium): exact hull of two coaxial round posts, rotated\n// for its diagonal tilt BEFORE the final translate (rotating an\n// already-translated shape about the world origin would also relocate it).\nfunction pillShape(cx, cz, halfLen, r, backY, depth, tiltDeg, segments = 32) {\n  const a = roundBtn(-halfLen, 0, r, backY, depth, segments);\n  const b = roundBtn(halfLen, 0, r, backY, depth, segments);\n  return hullOf([a, b]).rotate([0, tiltDeg, 0]).translate([cx, 0, cz]);\n}\n\n// A rounded rectangular panel: exact hull of 4 corner posts (same axis/length).\nfunction roundedPanel(xMin, xMax, zMin, zMax, r, front, back, segments = 40) {\n  const depth = back - front;\n  const posts = [\n    roundBtn(xMin + r, zMin + r, r, back, depth, segments),\n    roundBtn(xMax - r, zMin + r, r, back, depth, segments),\n    roundBtn(xMin + r, zMax - r, r, back, depth, segments),\n    roundBtn(xMax - r, zMax - r, r, back, depth, segments),\n  ];\n  return hullOf(posts);\n}\n\n// --- Body: portrait brick, ~16w x 5d x 26h (keeps the entry's overall size,\n// ~90:32:148 DMG ratio). Rounded via hull of 8 corner spheres inset by the\n// per-corner radius from each face — exact, no lattice waviness. Every\n// corner uses R1 EXCEPT the bottom-right (x=+X_W, z=-Z_H), which gets the\n// larger R2 for the classic asymmetric curve.\nconst X_W = 8, Y_D = 2.5, Z_H = 13;\nconst R1 = 1.1, R2 = 1.5;\nconst FRONT = -2.5;   // body front face (features sit proud of / recessed into this)\nconst BACKY = -1.0;   // shared embed anchor so proud features fuse solidly into the body\n\nfunction cornerSphere(xs, ys, zs, r) {\n  const c = [xs - Math.sign(xs) * r, ys - Math.sign(ys) * r, zs - Math.sign(zs) * r];\n  return Manifold.sphere(r, 32).translate(c);\n}\nconst bodyCorners = [];\nfor (const xs of [-X_W, X_W]) {\n  for (const ys of [-Y_D, Y_D]) {\n    for (const zs of [-Z_H, Z_H]) {\n      const r = (xs === X_W && zs === -Z_H) ? R2 : R1;\n      bodyCorners.push(cornerSphere(xs, ys, zs, r));\n    }\n  }\n}\nconst bodyShell = hullOf(bodyCorners);\n\n// --- Screen bezel (dark charcoal/blue-gray) + LCD window (olive/pea-green),\n// upper half of the face, screen centered horizontally but nearer the TOP\n// of the bezel. LED at the bezel's left edge, halfway down.\nconst bezel = roundedPanel(-6.3, 6.3, 0.6, 11.8, 0.6, -2.85, BACKY);\n// Screen must be MORE proud than the bezel (not a subset volume sitting\n// behind it) — a shape wholly contained in an already-fused volume has no\n// surface of its own to expose, so it would paint 0 triangles and be\n// visually invisible (verified empirically while debugging label triangle\n// counts on this file).\nconst screen = roundedPanel(-4.5, 4.5, 4.6, 11.0, 0.3, -2.95, BACKY);\nconst led = roundBtn(-5.7, (0.6 + 11.8) / 2, 0.35, BACKY, BACKY - -3.05, 20);\n\n// --- D-pad: dark burgundy/magenta CROSS (not a disc), left side of the lower\n// half, sitting in a shallow round recess with a small center dimple.\nconst DPAD_CX = -4.6, DPAD_CZ = -6.2;\nconst dpadFront = -2.90;\nconst dpadArmH = box([DPAD_CX - 2.3, dpadFront, DPAD_CZ - 0.7], [DPAD_CX + 2.3, BACKY, DPAD_CZ + 0.7]);\nconst dpadArmV = box([DPAD_CX - 0.7, dpadFront, DPAD_CZ - 2.3], [DPAD_CX + 0.7, BACKY, DPAD_CZ + 2.3]);\nconst dpadDimple = Manifold.sphere(0.55, 20).translate([DPAD_CX, dpadFront + 0.1, DPAD_CZ]);\nconst dpad = dpadArmH.add(dpadArmV).subtract(dpadDimple);\nconst dpadRecess = roundBtn(DPAD_CX, DPAD_CZ, 2.6, FRONT + 0.35, 0.55);\n\n// --- A/B action buttons: round, burgundy/magenta, on a diagonal — A upper\n// right, B lower left — each in its own shallow recess. The pair sits\n// slightly higher (average z) than the D-pad center.\nconst BTN_R = 1.25;\nconst btnB = roundBtn(2.8, -6.0, BTN_R, BACKY, BACKY - -2.95);\nconst btnA = roundBtn(5.3, -4.2, BTN_R, BACKY, BACKY - -2.95);\nconst btnBRecess = roundBtn(2.8, -6.0, 1.4, FRONT + 0.35, 0.55);\nconst btnARecess = roundBtn(5.3, -4.2, 1.4, FRONT + 0.35, 0.55);\n\n// --- Start / Select: two small gray pills, side by side, below and between\n// the D-pad and A/B, each with a slight ~25 deg diagonal tilt and its own\n// recessed oval.\nconst startBtn = pillShape(-1.4, -9.6, 0.55, 0.5, BACKY, BACKY - -2.85, -25);\nconst selectBtn = pillShape(1.4, -9.6, 0.55, 0.5, BACKY, BACKY - -2.85, -25);\nconst startRecess = pillShape(-1.4, -9.6, 0.75, 0.65, FRONT + 0.3, 0.5, -25);\nconst selectRecess = pillShape(1.4, -9.6, 0.75, 0.65, FRONT + 0.3, 0.5, -25);\n\n// --- Speaker grill: six parallel diagonal slots (~30 deg from vertical,\n// i.e. rotated ~60 deg from horizontal), evenly spaced, recessed body-color\n// grooves at the bottom-right of the face.\nfunction grillSlot(cx, cz, len, halfThick, tiltDeg) {\n  return box([-len / 2, FRONT - 0.25, -halfThick], [len / 2, FRONT + 0.3, halfThick])\n    .rotate([0, tiltDeg, 0])\n    .translate([cx, 0, cz]);\n}\nconst grillSlots = [];\nfor (let i = 0; i < 6; i++) {\n  grillSlots.push(grillSlot(5.0, -6.2 - i * 0.6, 2.0, 0.11, -60));\n}\nconst grillCut = Manifold.compose(grillSlots);\n\n// --- Assemble: cut all recesses + the grill into the bare shell, then add\n// every proud feature, then label 'body' as the whole result.\nconst bodyCut = bodyShell\n  .subtract(dpadRecess)\n  .subtract(btnARecess)\n  .subtract(btnBRecess)\n  .subtract(startRecess)\n  .subtract(selectRecess)\n  .subtract(grillCut);\n\n// Label each piece BEFORE the final union (not as a duplicate overlay added\n// after the fact) — api.label() stamps a fresh originalID that the boolean\n// union tracks through to the output mesh, one time each. A duplicate\n// congruent shape re-added on top of an already-fused body can resolve to 0\n// triangles (confirmed against the prior version of this file, where the\n// bezel region silently painted nothing for exactly this reason).\nconst bodyL = label(bodyCut, 'body');\nconst bezelL = label(bezel, 'bezel');\nconst screenL = label(screen, 'screen');\nconst ledL = label(led, 'led');\nconst dpadL = label(dpad, 'dpad');\nconst btnAL = label(btnA, 'btnA');\nconst btnBL = label(btnB, 'btnB');\nconst ssL = label(startBtn.add(selectBtn), 'startselect');\n\nreturn bodyL.add(bezelL).add(screenL).add(ledL)\n  .add(dpadL).add(btnAL).add(btnBL).add(ssL);\n})();\napi.paint.label(\"body\", [0.82, 0.79, 0.72]);\napi.paint.label(\"bezel\", [0.251, 0.251, 0.361]);\napi.paint.label(\"screen\", [0.506, 0.561, 0.345]);\napi.paint.label(\"led\", [0.85, 0.08, 0.08]);\napi.paint.label(\"dpad\", [0.58, 0.10, 0.32]);\napi.paint.label(\"btnA\", [0.58, 0.10, 0.32]);\napi.paint.label(\"btnB\", [0.58, 0.10, 0.32]);\napi.paint.label(\"startselect\", [0.55, 0.55, 0.58]);\nreturn __pwModel;\n",
