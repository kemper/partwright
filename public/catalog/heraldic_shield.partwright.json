      "index": 1,
      "code": "const { Manifold, CrossSection, label } = api;\n\n// Build the shield as 4 separately-labeled quarter slabs so each color\n// is exactly one connected labeled piece — no fan-bleed, crisp quarter lines.\n// Shield stands Z-up. Front face toward -Y.\n// CrossSection is in the XY plane; extrude along Z gives depth; then rotate(90,0,0)\n// maps old_Y -> new_Z (height up) and old_Z -> new_-Y (depth = front toward -Y).\n\nconst shieldH = 32;\nconst hw = 12;\nconst thickness = 3.5;\nconst midX = 0;\nconst midY = shieldH / 2; // split point for top/bottom\n\n// Full shield outline polygon (XY plane, Y=0 bottom point, Y=shieldH top arch)\nconst fullPoly = [\n  [0, 0],\n  [hw * 0.6, shieldH * 0.2],\n  [hw, shieldH * 0.5],\n  [hw, shieldH * 0.85],\n  [hw * 0.3, shieldH],\n  [0, shieldH + 1.5],\n  [-hw * 0.3, shieldH],\n  [-hw, shieldH * 0.85],\n  [-hw, shieldH * 0.5],\n  [-hw * 0.6, shieldH * 0.2],\n];\n\nconst fullCS = CrossSection.ofPolygons([fullPoly]);\n\n// Clip boxes for each quarter (in the XY pre-rotation space)\nconst big = 40;\nconst topLeftCS = fullCS.intersect(CrossSection.square([big, big]).translate([-big, midY]));\nconst topRightCS = fullCS.intersect(CrossSection.square([big, big]).translate([0, midY]));\nconst botLeftCS = fullCS.intersect(CrossSection.square([big, big]).translate([-big, -big + midY]));\nconst botRightCS = fullCS.intersect(CrossSection.square([big, big]).translate([0, -big + midY]));\n\n// Extrude each quarter then rotate to stand upright\nfunction slab(cs) {\n  return Manifold.extrude(cs, thickness).rotate([90, 0, 0]);\n}\n\n// Central boss on front face. Front face in world coords is at Y=0, protrudes in -Y.\n// Boss center slightly proud of face; overlaps into shield face by 0.5+ units.\nconst bossR = 2.8;\nconst bossZ = shieldH / 2 + 2; // world Z = mid-height of shield + a bit\nconst boss = Manifold.sphere(bossR, 32).translate([0, -bossR * 0.35, bossZ]);\n\nconst qTL = label(slab(topLeftCS), 'red'); // top-left: RED\nconst qTR = label(slab(topRightCS), 'blue'); // top-right: BLUE\nconst qBL = label(slab(botLeftCS), 'gold'); // bottom-left: GOLD\nconst qBR = label(slab(botRightCS), 'silver'); // bottom-right: SILVER\nconst bossL = label(boss, 'boss');\n\nreturn qTL.add(qTR).add(qBL).add(qBR).add(bossL);\n",
