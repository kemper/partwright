      "index": 1,
      "code": "const { Manifold, label } = api;\n\n// Helper: axis-aligned box from min/max corners\nfunction box(min, max) {\n  const s = [max[0] - min[0], max[1] - min[1], max[2] - min[2]];\n  const c = [(min[0] + max[0]) / 2, (min[1] + max[1]) / 2, (min[2] + max[2]) / 2];\n  return Manifold.cube(s, true).translate(c);\n}\n\n// 16-unit cube body, centered at origin\nconst body = Manifold.cube([16, 16, 16], true);\n\n// Front face features protrude toward -Y (the app's default front), overlapping\n// the body by 0.5 units so the boolean union fuses into one solid.\nconst fy = [-9, -7.5];\n\nfunction plate(x0, x1, z0, z1) {\n  return box([x0, fy[0], z0], [x1, fy[1], z1]);\n}\n\n// Corner rivets on the front face — small 2x2 raised squares near each corner.\nconst rivetsShape =\n  plate(-7, -5, 5, 7) // top-left\n  .add(plate(5, 7, 5, 7)) // top-right\n  .add(plate(-7, -5, -7, -5)) // bottom-left\n  .add(plate(5, 7, -7, -5)); // bottom-right\n\n// Corner rivets on the top face — same pattern protruding +Z.\nconst ty = [7.5, 9];\n\nfunction topPlate(x0, x1, y0, y1) {\n  return box([x0, y0, ty[0]], [x1, y1, ty[1]]);\n}\nconst topRivetsShape =\n  topPlate(-7, -5, -7, -5)\n  .add(topPlate(5, 7, -7, -5))\n  .add(topPlate(-7, -5, 5, 7))\n  .add(topPlate(5, 7, 5, 7));\n\nconst rivets = rivetsShape.add(topRivetsShape);\n\n// \"?\" glyph on the front face, built from raised blocks so it reads clearly as\n// a question mark: a hollow rounded top loop, the stroke dropping through the\n// centre, a gap, then a dot. Every plate overlaps the body face, so the glyph\n// fuses to the cube as a single manifold (no glyph-only floating pieces).\nconst qTopBar = plate(-3, 3, 4, 6); // top of the loop\nconst qLeftArch = plate(-3, -1, 1, 4); // left side of the loop\nconst qRightArch = plate(1, 3, 1, 4); // right side of the loop\nconst qHook = plate(-1, 3, 0, 2); // hook crossing back to centre\nconst qStem = plate(-1, 1, -2, 1); // centre stroke dropping down\nconst qDot = plate(-1, 1, -6, -4); // dot below the gap\n\nconst question = qTopBar\n  .add(qLeftArch)\n  .add(qRightArch)\n  .add(qHook)\n  .add(qStem)\n  .add(qDot);\n\nreturn label(body, 'body')\n  .add(label(rivets, 'rivets'))\n  .add(label(question, 'question'));\n",
