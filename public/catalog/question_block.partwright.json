      "index": 1,
      "code": "const { Manifold, label } = api;\n\n// Helper: axis-aligned box from min/max corners\nfunction box(min, max) {\n  const s = [max[0] - min[0], max[1] - min[1], max[2] - min[2]];\n  const c = [(min[0] + max[0]) / 2, (min[1] + max[1]) / 2, (min[2] + max[2]) / 2];\n  return Manifold.cube(s, true).translate(c);\n}\n\n// 16-unit cube body, centered at origin\nconst body = Manifold.cube([16, 16, 16], true);\n\n// Front face features are at y = -8 (front face) with relief protruding to y = -9\n// They overlap the body by 0.5 units so boolean union works\nconst fy = [-9, -7.5]; // front plate depth: protrudes 1 unit, overlaps 0.5\n\n// Helper for front-face plates\nfunction plate(x0, x1, z0, z1) {\n  return box([x0, fy[0], z0], [x1, fy[1], z1]);\n}\n\n// Corner rivets on the front face — small 2x2 raised squares at corners\n// Corners at x = ±5..±7, z = -7..-5 and z = 5..7\nconst rivetsShape =\n  plate(-7, -5, 5, 7) // top-left\n  .add(plate(5, 7, 5, 7)) // top-right\n  .add(plate(-7, -5, -7, -5)) // bottom-left\n  .add(plate(5, 7, -7, -5)); // bottom-right\n\n// Corner rivets on the top face — same pattern on z=8 face (top)\nconst ty = [7.5, 9]; // top plate extends upward\nfunction topPlate(x0, x1, y0, y1) {\n  return box([x0, y0, ty[0]], [x1, y1, ty[1]]);\n}\nconst topRivetsShape =\n  topPlate(-7, -5, -7, -5)\n  .add(topPlate(5, 7, -7, -5))\n  .add(topPlate(-7, -5, 5, 7))\n  .add(topPlate(5, 7, 5, 7));\n\nconst rivets = rivetsShape.add(topRivetsShape);\n\n// \"?\" glyph on the front face using raised cuboids\n// The ? consists of: a curved top arc (made of blocks), a gap, and a dot\n// Building it as pixel-art blocks:\n// Arc top: horizontal bar at top\n// Arc right: vertical bar going down-right\n// Arc bottom: small horizontal bar turning left\n// Vertical gap (empty)\n// Dot: small square at bottom\n\n// Scale factor: each \"pixel\" is ~2x2 units\n// Center of face: x=0, z=0. Overall glyph ~6 wide, 10 tall\n\n// Top arc of ?  (approx 3 blocks wide, 2 tall at top)\nconst qTop = plate(-3, 3, 3, 5); // top horizontal bar of arc\n\n// Right side going down\nconst qRight = plate(1, 3, 1, 4); // right-side vertical\n\n// Bottom of arc curving left\nconst qCurve = plate(-1, 1, 0, 2); // bottom of arc, center\n\n// Vertical stroke (the stem going down) — omit the gap naturally\nconst qStem = plate(-1, 1, -3, -1); // short stem below arc (left side)\n\n// Dot at bottom of ?\nconst qDot = plate(-1, 1, -6, -4);\n\nconst question = qTop.add(qRight).add(qCurve).add(qStem).add(qDot);\n\nreturn label(body, 'body')\n  .add(label(rivets, 'rivets'))\n  .add(label(question, 'question'));\n",
