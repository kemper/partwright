      "index": 1,
      "code": "const { Manifold, label, setCircularSegments } = api;\nsetCircularSegments(48);\n\nfunction box(min, max) {\n  const s = [max[0] - min[0], max[1] - min[1], max[2] - min[2]];\n  const c = [(min[0] + max[0]) / 2, (min[1] + max[1]) / 2, (min[2] + max[2]) / 2];\n  return Manifold.cube(s, true).translate(c);\n}\n\n// A front-facing disc (axis along -Y), centered on its own thickness so it\n// always straddles the front plane with generous overlap into the shell.\nfunction frontDisc(r, depth, x, z, yCenter) {\n  return Manifold.cylinder(depth, r, r, 48)\n    .translate([0, 0, -depth / 2]) // center on Z before laying it down\n    .rotate([90, 0, 0]) // lay the axis along Y\n    .translate([x, yCenter, z]); // place on the front face\n}\n\n// ---------------------------------------------------------------------------\n// Shell: 24w x 15h x 4d, centered at origin. Front face at y=-2 (faces -Y).\n// ---------------------------------------------------------------------------\nconst shellBody = box([-12, -2, -7.5], [12, 2, 7.5]);\n\n// Guide / sprocket holes: a short row of small holes along the bottom edge,\n// drilled straight through the front wall. Tiny + uncolored (subtracted faces\n// can't be labelled), but they read as the classic transport holes.\nconst holeR = 0.45;\nconst holeZ = -6.4;\nconst holeXs = [-4.5, -1.5, 1.5, 4.5];\nconst holes = Manifold.union(holeXs.map(hx => frontDisc(holeR, 1.6, hx, holeZ, -2.0)));\nconst shell = label(shellBody.subtract(holes), 'shell');\n\n// ---------------------------------------------------------------------------\n// Label window: large cream plate filling the upper face. The two reels sit\n// INSIDE this window (the iconic cassette layout).\n// ---------------------------------------------------------------------------\n// Back face seated 0.6 into the shell (overlap > 0.5) so it fuses cleanly;\n// front face proud 0.35 of the shell front (-2.0).\nconst labelPlate = label(box([-10, -2.35, 0.4], [10, -1.4, 6.9]), 'label');\n\n// ---------------------------------------------------------------------------\n// Tape-access window: darker recessed-look plate along the lower face, where\n// the tape is exposed. Sits proud just under the reels.\n// ---------------------------------------------------------------------------\nconst tapeWindow = label(box([-7.5, -2.25, -5.5], [7.5, -1.4, -1.2]), 'window');\n\n// ---------------------------------------------------------------------------\n// Reels: two black discs side-by-side, centred vertically inside the label\n// window. Each carries a lighter hub at its centre.\n// ---------------------------------------------------------------------------\nconst reelR = 2.9;\nconst reelZ = 3.6; // vertical centre of the label window\nconst reelLX = -5.0;\nconst reelRX = 5.0;\nconst reelYC = -1.5; // centred on thickness 2.4 -> spans y -2.7..-0.3\n\nconst reelL = frontDisc(reelR, 2.4, reelLX, reelZ, reelYC);\nconst reelR2 = frontDisc(reelR, 2.4, reelRX, reelZ, reelYC);\nconst reels = label(reelL.add(reelR2), 'reels');\n\n// Hubs: lighter discs, proud of the reels.\nconst hubR = 1.1;\nconst hubL = frontDisc(hubR, 2.9, reelLX, reelZ, -1.6);\nconst hubR2 = frontDisc(hubR, 2.9, reelRX, reelZ, -1.6);\nconst hubs = label(hubL.add(hubR2), 'hubs');\n\n// ---------------------------------------------------------------------------\n// Assemble (single watertight manifold; every additive part overlaps 0.5+).\n// ---------------------------------------------------------------------------\nreturn shell\n  .add(labelPlate)\n  .add(tapeWindow)\n  .add(reels)\n  .add(hubs);\n",
