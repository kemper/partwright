      "index": 1,
      "code": "const { Manifold, label, setCircularSegments } = api;\nsetCircularSegments(32);\n\nfunction box(min, max) {\n  const s = [max[0] - min[0], max[1] - min[1], max[2] - min[2]];\n  const c = [(min[0] + max[0]) / 2, (min[1] + max[1]) / 2, (min[2] + max[2]) / 2];\n  return Manifold.cube(s, true).translate(c);\n}\n\n// Shell: 24w x 15h x 4d, centered at origin, front face at y=-2\nconst shell = box([-12, -2, -7.5], [12, 2, 7.5]);\n\n// Reel windows: two circular recesses on the front face\n// Each reel: cylinder recessed into front face\nconst reelRadius = 2.8;\nconst reelDepth = 1.2;\nconst reelLX = -5;\nconst reelRX = 5;\nconst reelZ = 0.5;\n\n// Outer dark reel rings (cylinders slightly proud)\nconst reelL = Manifold.cylinder(reelDepth, reelRadius, reelRadius, 32).rotate([90, 0, 0]).translate([reelLX, -2.1, reelZ]);\nconst reelR = Manifold.cylinder(reelDepth, reelRadius, reelRadius, 32).rotate([90, 0, 0]).translate([reelRX, -2.1, reelZ]);\n\n// Hub cylinders at center of each reel (lighter)\nconst hubRadius = 1.2;\nconst hubL = Manifold.cylinder(reelDepth + 0.2, hubRadius, hubRadius, 32).rotate([90, 0, 0]).translate([reelLX, -2.2, reelZ]);\nconst hubR = Manifold.cylinder(reelDepth + 0.2, hubRadius, hubRadius, 32).rotate([90, 0, 0]).translate([reelRX, -2.2, reelZ]);\n\n// Label strip across upper front: from x=-10 to x=10, z=2 to 7, y front\nconst labelStrip = box([-10, -2.1, 1.5], [10, -1.8, 7.0]);\n\n// Tape window cutout (below center between reels) — a slot shape\nconst tapeWindow = box([-3.5, -2.2, -2.5], [3.5, -1.7, -0.5]);\n\n// Small guide holes row along bottom edge\nconst hole1 = Manifold.cylinder(0.4, 0.5, 0.5, 16).rotate([90, 0, 0]).translate([-4, -2.2, -6]);\nconst hole2 = Manifold.cylinder(0.4, 0.5, 0.5, 16).rotate([90, 0, 0]).translate([0, -2.2, -6]);\nconst hole3 = Manifold.cylinder(0.4, 0.5, 0.5, 16).rotate([90, 0, 0]).translate([4, -2.2, -6]);\n\n// Assemble: subtract tape window and holes from shell, then add features\nconst bodyBase = shell.subtract(tapeWindow).subtract(hole1).subtract(hole2).subtract(hole3);\n\nreturn label(bodyBase, 'shell')\n  .add(label(reelL.add(reelR), 'reels'))\n  .add(label(hubL.add(hubR), 'hubs'))\n  .add(label(labelStrip, 'label'));\n",
