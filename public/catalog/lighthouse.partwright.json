      "index": 1,
      "code": "const { Manifold, label } = api;\n\n// ============================================================\n// LIGHTHOUSE — bands built as GEOMETRY (no paintSlab).\n// The tower is ONE tapered cylinder, sliced into horizontal\n// bands by intersecting copies with full-XY Z-range boxes, then\n// labelled alternately so coloring-by-label is crisp & deterministic.\n// Everything overlaps into a single watertight manifold solid.\n// ============================================================\n\n// ---- Dimensions ----\nconst rockH = 4,\n  rockR = 13; // gray rock base: z in [0, 4]\nconst towerZ0 = 3,\n  towerH = 27; // tower: z in [3, 30] (overlaps rock by 1.0)\nconst rBot = 8.5,\n  rTop = 5.0; // tapered tower radii\nconst galleryZ0 = 29,\n  galleryH = 2.2,\n  galleryR = 7.0; // ring: z in [29, 31.2]\nconst lampZ0 = 30.5,\n  lampH = 7,\n  lampR = 4.3; // lamp room: z in [30.5, 37.5]\nconst domeBaseZ = 36.5,\n  domeR = 4.5; // dome cap (overlaps lamp top by 1.0)\n\n// ---- Gray rock base (slightly tapered footing) ----\nconst rock = label(Manifold.cylinder(rockH, rockR, rockR * 0.85), 'rock');\n\n// ---- Tower body: cut openings FIRST so the bores inherit band labels ----\nlet tower = Manifold.cylinder(towerH, rBot, rTop).translate([0, 0, towerZ0]);\n\n// Arched doorway at the base, facing +Y.\nconst doorBodyZ = towerZ0 + 3,\n  doorW = 3.2,\n  doorTall = 6;\nconst doorRect = Manifold.cube([doorW, 8, doorTall], true).translate([0, rBot, doorBodyZ]);\nconst doorArch = Manifold.cylinder(8, doorW / 2, doorW / 2)\n  .rotate([90, 0, 0])\n  .translate([0, rBot + 4, doorBodyZ + doorTall / 2]);\ntower = tower.subtract(doorRect.add(doorArch));\n\n// Two small portholes up the shaft, facing +Y.\nlet windows = null;\nfor (const wz of [towerZ0 + 11, towerZ0 + 18]) {\n  const w = Manifold.cylinder(8, 0.9, 0.9).rotate([90, 0, 0]).translate([0, rBot + 2, wz]);\n  windows = windows ? windows.add(w) : w;\n}\ntower = tower.subtract(windows);\n\n// ---- Slice the tower into horizontal bands and label alternately ----\nconst W = rBot * 4; // box footprint comfortably wider than the tower\nconst boxForZ = (zlo, zhi) =>\n  Manifold.cube([W, W, zhi - zlo], true).translate([0, 0, (zlo + zhi) / 2]);\n\nconst nBands = 7;\nconst bandH = towerH / nBands; // exact division -> clean abutting Z planes\nlet towerBanded = null;\nfor (let i = 0; i < nBands; i++) {\n  const zlo = towerZ0 + i * bandH;\n  const zhi = towerZ0 + (i + 1) * bandH;\n  const slice = tower.intersect(boxForZ(zlo, zhi)); // one horizontal band\n  const named = label(slice, (i % 2 === 0) ? 'bandRed' : 'bandWhite');\n  towerBanded = towerBanded ? towerBanded.add(named) : named;\n}\n\n// ---- Gallery ring (dark) — bites into the tower top ----\nconst gallery = label(Manifold.cylinder(galleryH, galleryR, galleryR).translate([0, 0, galleryZ0]), 'gallery');\n\n// ---- Glass / gold lamp room ----\nconst lamp = label(Manifold.cylinder(lampH, lampR, lampR).translate([0, 0, lampZ0]), 'lamp');\n\n// ---- Black dome cap (upper hemisphere) + small finial ----\nconst domeSphere = Manifold.sphere(domeR).translate([0, 0, domeBaseZ]);\nconst cutBelow = Manifold.cube([40, 40, 40], true).translate([0, 0, domeBaseZ - 20]);\nlet dome = domeSphere.subtract(cutBelow);\nconst finial = Manifold.cylinder(1.6, 0.5, 0.35).translate([0, 0, domeBaseZ + domeR - 0.5]);\ndome = label(dome.add(finial), 'dome');\n\n// ---- Union everything into ONE watertight solid ----\nreturn rock\n  .add(towerBanded)\n  .add(gallery)\n  .add(lamp)\n  .add(dome);\n",
