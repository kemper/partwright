      "index": 1,
      "code": "const { Manifold, label, setCircularSegments } = api;\nsetCircularSegments(48);\n\n// --- Rock base (gray) : z in [0, 3.5] ---\nconst rockBase = label(Manifold.cylinder(3.5, 12, 12, 48), 'rockBase');\n\n// --- Tower: ONE smooth tapered cylinder (the key rebuild) ---\n// Spans z in [2.5, 29.5]; base overlaps the rock by 1.0 unit so it unions.\n// Coloured WHITE by label, then RED bands are added with paintSlab(smooth)\n// so the stripe edges are clean and straight across the coarse mesh.\nconst towerZ0 = 2.5;\nconst towerH = 27; // tower z-range: [2.5, 29.5]\nconst tower = label(\n  Manifold.cylinder(towerH, 8, 5.5, 48).translate([0, 0, towerZ0]),\n  'tower'\n);\n\n// --- Small arched doorway at the base (subtract) ---\nconst door = Manifold.cube([3, 6, 6], true).translate([0, 8, 5.5]); // z in [2.5, 8.5]\nconst towerWithDoor = tower.subtract(door);\n\n// --- Gallery ring near the top : z in [28.5, 30.5] ---\n// Radius 7 > tower radius (~5.75) at this height, so it bites into the tower.\nconst gallery = label(Manifold.cylinder(2, 7, 7, 48).translate([0, 0, 28.5]), 'gallery');\n\n// --- Glass / gold lamp room : z in [30, 37] (overlaps gallery by 0.5) ---\nconst lampRoom = label(Manifold.cylinder(7, 4.2, 4.2, 48).translate([0, 0, 30]), 'lampRoom');\n\n// --- Black dome cap (upper hemisphere) : z in [36.5, 41.3] ---\n// Sphere centred at z=36.5, lower half cut off; flat base at z=36.5 overlaps\n// the lamp-room top (z=37) so it unions.\nconst sphereCz = 36.5;\nconst domeSphere = Manifold.sphere(4.8, 48).translate([0, 0, sphereCz]);\nconst cutBelow = Manifold.cube([16, 16, 16], true).translate([0, 0, sphereCz - 8]);\nconst dome = label(domeSphere.subtract(cutBelow), 'dome');\n\nreturn rockBase\n  .add(towerWithDoor)\n  .add(gallery)\n  .add(lampRoom)\n  .add(dome);\n",
