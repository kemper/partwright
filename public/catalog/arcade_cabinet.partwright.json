      "index": 1,
      "code": "const { Manifold, label } = api;\n\n// Arcade cabinet — Z-up, front faces -Y. ONE watertight solid.\nfunction box(min, max) {\n  const s = [max[0] - min[0], max[1] - min[1], max[2] - min[2]];\n  const c = [(min[0] + max[0]) / 2, (min[1] + max[1]) / 2, (min[2] + max[2]) / 2];\n  return Manifold.cube(s, true).translate(c);\n}\n\nconst HW = 9,\n  FRONT = -6,\n  BACK = 6,\n  BODY_TOP = 34;\n\n// 1) One tall body box spanning the FULL height — top is part of the body, no gap.\nlet body = box([-HW, FRONT, 0], [HW, BACK, BODY_TOP]);\n\n// Sloped crown: shave the top so the silhouette leans forward. Pure subtraction.\nconst slope = box([-HW - 1, -10, 0], [HW + 1, 10, 12])\n  .rotate([26, 0, 0])\n  .translate([0, BACK + 2.0, BODY_TOP - 1.0]);\nbody = body.subtract(slope);\n\n// 2) Screen: a genuine recess (pocket subtracted, blue plate set back).\nconst sX = 6.5,\n  sZlo = 18.5,\n  sZhi = 27.5,\n  recess = 1.4;\nconst pocket = box([-sX, FRONT - 0.1, sZlo], [sX, FRONT + recess, sZhi]);\nbody = body.subtract(pocket);\nconst screen = box([-sX, FRONT + recess - 0.2, sZlo], [sX, FRONT + recess + 0.5, sZhi]);\n\n// 3) Marquee: red header band flush across the top of the front, small bezel overhang.\nconst marquee = box([-HW, FRONT - 1.5, 28.5], [HW, FRONT + 1.0, 33]);\n\n// 4) Control panel: forward-protruding deck below the screen, overlapping the body.\nconst PANEL_FRONT = -11,\n  PANEL_TOP = 15;\nconst panel = box([-HW, PANEL_FRONT, 11], [HW, FRONT + 1.0, PANEL_TOP]);\n\n// 5) Joystick (dark): stem + ball.\nconst ctrlY = -8.0;\nconst joyStem = Manifold.cylinder(3.2, 0.9, 0.9).translate([-4.5, ctrlY, 13.5]);\nconst joyBall = Manifold.sphere(1.4).translate([-4.5, ctrlY, 17.2]);\nconst joystick = joyStem.add(joyBall);\n\n// 6) Buttons (yellow): three round caps overlapping the deck top.\nfunction button(x) {\n  return Manifold.cylinder(1.2, 1.05, 1.05).translate([x, ctrlY, 14.2]);\n}\nconst buttons = button(0.5).add(button(3.0)).add(button(5.5));\n\n// 7) Coin slot: lighter-gray plate low on the front.\nconst coin = box([-1.6, FRONT - 0.6, 5.5], [1.6, FRONT + 0.6, 7.2]);\n\nconst baseBody = body.add(label(panel, 'body'));\n\nreturn label(baseBody, 'body')\n  .add(label(marquee, 'marquee'))\n  .add(label(screen, 'screen'))\n  .add(label(joystick, 'joystick'))\n  .add(label(buttons, 'buttons'))\n  .add(label(coin, 'coinslot'));\n",
