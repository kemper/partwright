      "index": 1,
      "code": "const { Manifold, label, setCircularSegments } = api;\nsetCircularSegments(32);\n\nfunction box(min, max) {\n  const s = [max[0] - min[0], max[1] - min[1], max[2] - min[2]];\n  const c = [(min[0] + max[0]) / 2, (min[1] + max[1]) / 2, (min[2] + max[2]) / 2];\n  return Manifold.cube(s, true).translate(c);\n}\n\n// Arcade cabinet: Z-up, front facing -Y.\n// Main body: x=-9..9, y=-5..5, z=0..28\nconst mainBody = box([-9, -5, 0], [9, 5, 28]);\n\n// Control panel: protrudes forward at z=10-17\nconst ctrlPanel = box([-9, -8, 10], [9, -5, 17]);\n\n// Marquee: protrudes forward at top z=28..34\nconst marqueeBox = box([-9, -8, 28], [9, -4, 34]);\n\n// Top cap\nconst topCap = box([-9, -5, 34], [9, 5, 36]);\n\n// Screen panel on front face\nconst screen = box([-6.5, -5.3, 18], [6.5, -3.5, 27.5]);\n\n// Joystick on control panel\nconst joyStem = Manifold.cylinder(3.5, 0.9, 0.9, 16).translate([-3.5, -8.5, 12]);\nconst joyBall = Manifold.sphere(1.3, 16).translate([-3.5, -8.5, 15.5]);\n\n// Buttons: 3 cylinders on control panel\nconst btn1 = Manifold.cylinder(0.7, 1.0, 1.0, 16).translate([0.5, -8.5, 14]);\nconst btn2 = Manifold.cylinder(0.7, 1.0, 1.0, 16).translate([2.5, -8.5, 14]);\nconst btn3 = Manifold.cylinder(0.7, 1.0, 1.0, 16).translate([4.5, -8.5, 14]);\n\n// Coin slot\nconst coinSlot = box([-1.2, -5.3, 5], [1.2, -4.5, 6.2]);\n\n// Key insight from boombox: include everything in base body EXCEPT what we want labeled.\n// The base body (unlabeled) includes mainBody + ctrlPanel + topCap.\n// marqueeBox, screen, joystick, buttons, coinSlot are added as LABELED shapes only.\n// They must overlap base body by 0.5+ to keep 1 component.\n\nconst baseBody = mainBody.add(ctrlPanel).add(topCap);\n\nreturn label(baseBody, 'body')\n  .add(label(marqueeBox, 'marquee'))\n  .add(label(screen, 'screen'))\n  .add(label(joyStem.add(joyBall), 'joystick'))\n  .add(label(btn1.add(btn2).add(btn3), 'buttons'))\n  .add(label(coinSlot, 'coinslot'));\n",
      "label": "v1",
