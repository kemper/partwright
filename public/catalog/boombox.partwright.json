      "index": 1,
      "code": "const { Manifold, label, setCircularSegments } = api;\nsetCircularSegments(32);\n\nfunction box(min, max) {\n  const s = [max[0] - min[0], max[1] - min[1], max[2] - min[2]];\n  const c = [(min[0] + max[0]) / 2, (min[1] + max[1]) / 2, (min[2] + max[2]) / 2];\n  return Manifold.cube(s, true).translate(c);\n}\n\n// Main body: 28w x 16h x 8d, front at y=-4\nconst body = box([-14, -4, -8], [14, 4, 8]);\n\n// Speaker rims: colored rings, added first (larger radius = 5)\nconst rimR = 5.0;\nconst rimH = 1.5; // 1.5 units deep into body\nconst spkLRim = Manifold.cylinder(rimH, rimR, rimR, 32).rotate([90, 0, 0]).translate([-9, -4, 0]);\nconst spkRRim = Manifold.cylinder(rimH, rimR, rimR, 32).rotate([90, 0, 0]).translate([9, -4, 0]);\n\n// Speaker cones: dark inner disc (smaller), protrudes more\nconst coneR = 3.5;\nconst coneH = 2.0; // protrudes 2 units into body\nconst spkLCone = Manifold.cylinder(coneH, coneR, coneR, 32).rotate([90, 0, 0]).translate([-9, -4, 0]);\nconst spkRCone = Manifold.cylinder(coneH, coneR, coneR, 32).rotate([90, 0, 0]).translate([9, -4, 0]);\n\n// Center cassette deck\nconst deck = box([-3.5, -4.1, -2.5], [3.5, -2.5, 2.5]);\n\n// Control buttons\nconst bY0 = -4.1;\nconst bY1 = -3.2;\nconst btn1 = box([-3.0, bY0, -5.0], [-2.2, bY1, -4.4]);\nconst btn2 = box([-1.8, bY0, -5.0], [-1.0, bY1, -4.4]);\nconst btn3 = box([-0.4, bY0, -5.0], [0.4, bY1, -4.4]);\nconst btn4 = box([0.8, bY0, -5.0], [1.6, bY1, -4.4]);\nconst btn5 = box([2.0, bY0, -5.0], [2.8, bY1, -4.4]);\n\n// Handle on top: arch\nconst handlePostL = box([-4.5, -0.6, 8], [-3.5, 0.6, 11]);\nconst handlePostR = box([3.5, -0.6, 8], [4.5, 0.6, 11]);\nconst handleBar = box([-3.5, -0.5, 10.3], [3.5, 0.5, 11]);\n\n// Build union step by step using labels:\n// 1. Body (unlabeled base)\n// 2. Add labeled rims\n// 3. Add labeled cones (on top of rims — the NEW part of cones gets labeled)\n// 4. Add rest\n\nconst bodyBase = label(body, 'body');\nconst rimsLabeled = label(spkLRim.add(spkRRim), 'rims');\nconst conesLabeled = label(spkLCone.add(spkRCone), 'speakers');\nconst deckLabeled = label(deck, 'deck');\nconst btnsLabeled = label(btn1.add(btn2).add(btn3).add(btn4).add(btn5), 'buttons');\nconst handleLabeled = label(handlePostL.add(handlePostR).add(handleBar), 'handle');\n\nreturn bodyBase\n  .add(rimsLabeled)\n  .add(conesLabeled)\n  .add(deckLabeled)\n  .add(btnsLabeled)\n  .add(handleLabeled);\n",
