      "index": 1,
      "code": "// Unicorn horn — the directional-surface primitive doing a HELIX that spirals\n// up a tapering, gently-curved path. One sdf.tube call; taper shrinks the\n// radius toward the tip while the spiral stays locked to the path frame.\nconst { sdf } = api;\n\nconst horn = sdf.tube(\n  [[0, 0, 0], [0, 0, 10], [3, 0, 45], [5, 0, 82]],   // base → gentle forward curve → tip\n  8,\n  { profile: 'helix', count: 2, turns: 6, depth: 1.5, taper: 0.12 },\n).label('horn');\n\nconst model = horn.build({ edgeLength: 0.45 });\napi.paint.label({ label: 'horn', color: '#e9c25a' });\n// Golden horn: metallic viewport shading (presentation only — geometry,\n// exports and the baked thumbnail are untouched).\napi.material('gold');\nreturn model;\n",
