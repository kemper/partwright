    {
      "index": 1,
      "code": "\nconst { Manifold, CrossSection } = api;\n\nconst bodyH = 30;\nconst bodyR = 6;\nconst body = Manifold.cylinder(bodyH, bodyR, bodyR * 0.95);\n\n// Nose ogive\nconst noseH = 14;\nconst noseProfile = [[0, 0]];\nconst samples = 24;\nfor (let i = 0; i <= samples; i++) {\n  const t = i / samples;\n  const r = bodyR * 0.95 * Math.cos(t * Math.PI / 2);\n  const y = noseH * t;\n  if (i === 0) noseProfile.push([bodyR * 0.95, 0]);\n  else noseProfile.push([Math.max(r, 0.01), y]);\n}\nnoseProfile.push([0, noseH]);\nconst noseCS = CrossSection.ofPolygons([noseProfile]);\nconst nose = Manifold.revolve(noseCS).translate([0, 0, bodyH - 0.5]);\n\nconst collar = Manifold.cylinder(1.2, bodyR + 0.6, bodyR + 0.6).translate([0, 0, bodyH - 0.6]);\nconst baseRing = Manifold.cylinder(1.5, bodyR + 0.4, bodyR + 0.4);\n\n// Fins\nconst finProfile = [[0, 0], [bodyR + 5, 0], [0, 12]];\nconst finCS = CrossSection.ofPolygons([finProfile]);\nlet fin = finCS.extrude(0.8, 0, 0, 1, true);\nfin = fin.rotate([90, 0, 0]);\nfin = fin.translate([bodyR - 0.5, 0, 0]);\nconst finsList = [];\nfor (let i = 0; i < 3; i++) {\n  finsList.push(fin.rotate([0, 0, (360 / 3) * i]));\n}\nconst fins = Manifold.union(finsList);\n\n// Window\nconst windowR = 1.8;\nconst windowZ = bodyH * 0.65;\nconst windowCutter = Manifold.cylinder(3, windowR, windowR).rotate([90, 0, 0]).translate([0, -bodyR - 0.5, windowZ]);\n\nconst frameOuter = Manifold.cylinder(1.0, windowR + 0.6, windowR + 0.6).rotate([90, 0, 0]).translate([0, -bodyR + 0.2, windowZ]);\nconst frameInner = Manifold.cylinder(1.5, windowR + 0.1, windowR + 0.1).rotate([90, 0, 0]).translate([0, -bodyR + 0.1, windowZ]);\nconst frame = frameOuter.subtract(frameInner);\n\n// Nozzle: bottom at z=-4, top at z=1 (overlaps base ring). \n// Hole goes ALL the way through (from below the nozzle bottom up into body interior cavity).\n// To avoid sealing the cavity, we'll punch the hole upward through the body floor.\nconst nozzleH = 4;\nconst nozzle = Manifold.cylinder(nozzleH, 3.5, 5).translate([0, 0, -nozzleH + 1]);\n// Hole spans from z=-5 (below) up to z=2 (into body). This carves a tunnel from\n// outside-below into body interior, but since body is solid the tunnel ends at\n// ... actually we want to NOT seal the cavity. Make hole break through bottom only.\nconst nozzleHole = Manifold.cylinder(nozzleH + 1, 2.9, 4.4).translate([0, 0, -nozzleH + 0.5]);\n// Now hole spans z = -3.5 to 1.5, which goes ABOVE z=0 into the body. Subtracting from\n// (body+nozzle) creates a tunnel from outside-bottom into body interior. Body interior\n// is solid so the tunnel just dead-ends — same problem.\n// SOLUTION: also subtract a smaller cylinder from the body interior to make a thrust chamber\n// that connects out through the nozzle. This forms one connected open cavity.\nconst thrustChamber = Manifold.cylinder(6, 2.9, 2.9).translate([0, 0, 1]);\n\nlet rocket = body;\nrocket = rocket.add(nose);\nrocket = rocket.add(collar);\nrocket = rocket.add(baseRing);\nrocket = rocket.add(fins);\nrocket = rocket.subtract(windowCutter);\nrocket = rocket.add(frame);\nrocket = rocket.add(nozzle);\nrocket = rocket.subtract(nozzleHole);\nrocket = rocket.subtract(thrustChamber);\n\nreturn rocket;\n",
      "label": "v1 - retro rocket",
