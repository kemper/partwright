      "index": 1,
      "code": "// Colors below were migrated from saved paint into code via api.paint.*\n// (the model is now self-colouring; see /ai/colors.md). Edit colours here.\nconst __pwModel = (() => {\n\nconst { Manifold, CrossSection, smoothWeld } = api;\n\nconst bodyH = 30;\nconst bodyR = 6;\nconst body = Manifold.cylinder(bodyH, bodyR, bodyR * 0.95);\n\n// Nose ogive\nconst noseH = 14;\nconst noseProfile = [[0, 0]];\nconst samples = 24;\nfor (let i = 0; i <= samples; i++) {\n  const t = i / samples;\n  const r = bodyR * 0.95 * Math.cos(t * Math.PI / 2);\n  const y = noseH * t;\n  if (i === 0) noseProfile.push([bodyR * 0.95, 0]);\n  else noseProfile.push([Math.max(r, 0.01), y]);\n}\nnoseProfile.push([0, noseH]);\nconst noseCS = CrossSection.ofPolygons([noseProfile]);\nconst nose = Manifold.revolve(noseCS).translate([0, 0, bodyH - 0.5]);\n\nconst collar = Manifold.cylinder(1.2, bodyR + 0.6, bodyR + 0.6).translate([0, 0, bodyH - 0.6]);\nconst baseRing = Manifold.cylinder(1.5, bodyR + 0.4, bodyR + 0.4);\n\n// Fins\nconst finProfile = [[0, 0], [bodyR + 5, 0], [0, 12]];\nconst finCS = CrossSection.ofPolygons([finProfile]);\nlet fin = finCS.extrude(0.8, 0, 0, 1, true);\nfin = fin.rotate([90, 0, 0]);\nfin = fin.translate([bodyR - 0.5, 0, 0]);\nconst finsList = [];\nfor (let i = 0; i < 3; i++) {\n  finsList.push(fin.rotate([0, 0, (360 / 3) * i]));\n}\n\n// Fin roots get a small fillet where the flat fin plane meets the curved\n// body (classic retro rockets don't have a hard crease there). smoothWeld\n// remeshes its WHOLE input domain on a lattice, so we keep the weld box as\n// TIGHT as possible around just the root seam itself (the flared wide base\n// of the fin and its straight diagonal/bottom edges are excluded and stay\n// exact, untouched geometry) — both to hold the tri budget and, more\n// importantly, so those already-crisp straight edges aren't needlessly\n// re-triangulated onto the lattice (which is what produced a stair-stepped\n// look on a first pass with a looser box). The smoothed root nub is\n// stitched back onto the untouched rest of the body AND the untouched\n// outboard blade with a generous overlap shell so every piece fuses\n// cleanly. Each fin gets its own patch (rotated into place).\n// Radius stays under ~40% of the 0.8-thick fin blade so the blade itself\n// isn't eroded away by the fillet.\nconst finWeldRadius = 0.32;\n// Patch box (kept region, used for the weld) is slightly larger than the\n// cut box (removed from the plain body/fin) so the welded patch and the\n// rest of the body/fin overlap by ~0.5 units along every cut face. Sized\n// to hug the root line (world x=5.5) by only a couple of fillet radii on\n// either side, not the fin's full 11-unit reach.\nconst patchBoxKeep = Manifold.cube([4.5, 2.6, 15], true).translate([5.75, 0, 6.25]); // x:3.5..8 y:-1.3..1.3 z:-1.25..13.75\nconst patchBoxCut = Manifold.cube([3.5, 2, 14.5], true).translate([5.75, 0, 6.25]); // x:4..7.5 y:-1..1 z:-1..13.5\n\nlet bodyRest = body;\nconst weldedPatches = [];\nconst finOutboardRests = [];\nfor (let i = 0; i < 3; i++) {\n  const angle = (360 / 3) * i;\n  const keepBox = patchBoxKeep.rotate([0, 0, angle]);\n  const cutBox = patchBoxCut.rotate([0, 0, angle]);\n  const bodyPatch = body.intersect(keepBox);\n  const finRootPatch = finsList[i].intersect(keepBox);\n  weldedPatches.push(smoothWeld([bodyPatch, finRootPatch], { radius: finWeldRadius, resolution: 220 }));\n  finOutboardRests.push(finsList[i].subtract(cutBox));\n  bodyRest = bodyRest.subtract(cutBox);\n}\nconst bodyWithFins = Manifold.union([bodyRest, ...weldedPatches, ...finOutboardRests]); // full-height body with filleted fin roots\n\n// Window\nconst windowR = 1.8;\nconst windowZ = bodyH * 0.65;\nconst windowCutter = Manifold.cylinder(3, windowR, windowR).rotate([90, 0, 0]).translate([0, -bodyR - 0.5, windowZ]);\n\nconst frameOuter = Manifold.cylinder(1.0, windowR + 0.6, windowR + 0.6).rotate([90, 0, 0]).translate([0, -bodyR + 0.2, windowZ]);\nconst frameInner = Manifold.cylinder(1.5, windowR + 0.1, windowR + 0.1).rotate([90, 0, 0]).translate([0, -bodyR + 0.1, windowZ]);\nconst frame = frameOuter.subtract(frameInner);\n\n// Nozzle: bottom at z=-4, top at z=1 (overlaps base ring). \n// Hole goes ALL the way through (from below the nozzle bottom up into body interior cavity).\n// To avoid sealing the cavity, we'll punch the hole upward through the body floor.\nconst nozzleH = 4;\nconst nozzle = Manifold.cylinder(nozzleH, 3.5, 5).translate([0, 0, -nozzleH + 1]);\n// Hole spans from z=-5 (below) up to z=2 (into body). This carves a tunnel from\n// outside-below into body interior, but since body is solid the tunnel ends at\n// ... actually we want to NOT seal the cavity. Make hole break through bottom only.\nconst nozzleHole = Manifold.cylinder(nozzleH + 1, 2.9, 4.4).translate([0, 0, -nozzleH + 0.5]);\n// Now hole spans z = -3.5 to 1.5, which goes ABOVE z=0 into the body. Subtracting from\n// (body+nozzle) creates a tunnel from outside-bottom into body interior. Body interior\n// is solid so the tunnel just dead-ends — same problem.\n// SOLUTION: also subtract a smaller cylinder from the body interior to make a thrust chamber\n// that connects out through the nozzle. This forms one connected open cavity.\nconst thrustChamber = Manifold.cylinder(6, 2.9, 2.9).translate([0, 0, 1]);\n\nlet rocket = bodyWithFins;\nrocket = rocket.add(nose);\nrocket = rocket.add(collar);\nrocket = rocket.add(baseRing);\nrocket = rocket.subtract(windowCutter);\nrocket = rocket.add(frame);\nrocket = rocket.add(nozzle);\nrocket = rocket.subtract(nozzleHole);\nrocket = rocket.subtract(thrustChamber);\n\nreturn rocket;\n})();\napi.paint.slab({ axis: \"z\", offset: -5, thickness: 55, color: [0.96, 0.93, 0.85] });\napi.paint.slab({ axis: \"x\", offset: 6.3, thickness: 12, color: [0.85, 0.15, 0.12] });\napi.paint.slab({ normal: [-0.5, 0.866, 0], offset: 6.3, thickness: 12, color: [0.85, 0.15, 0.12] });\napi.paint.slab({ normal: [-0.5, -0.866, 0], offset: 6.3, thickness: 12, color: [0.85, 0.15, 0.12] });\napi.paint.slab({ axis: \"z\", offset: 30.6, thickness: 15, color: [0.85, 0.15, 0.12] });\napi.paint.slab({ axis: \"z\", offset: 29.3, thickness: 1.4, color: [0.85, 0.68, 0.2] });\napi.paint.slab({ axis: \"z\", offset: -0.1, thickness: 1.6, color: [0.85, 0.68, 0.2] });\napi.paint.slab({ axis: \"z\", offset: -4, thickness: 4.1, color: [0.3, 0.3, 0.33] });\nreturn __pwModel;\n",
