      "index": 1,
      "code": "// Chess Rook (Castle) — hollow, turned-IVORY look with a darker turned foot ring.\nconst { Manifold, CrossSection, label } = api;\n\nconst segments = 48; // smooth circular geometry\n\n// 1. FOOT BAND — flared base, a separate labelled solid (darker accent). Z 0 -> 2.2.\nconst footProfile = [\n  [0, 0.0],\n  [6.4, 0.0],\n  [6.4, 1.0],\n  [5.5, 1.7],\n  [4.7, 2.2],\n  [0, 2.2],\n];\nconst foot = label(\n  Manifold.revolve(CrossSection.ofPolygons([footProfile]), segments),\n  'foot',\n);\n\n// 2. MAIN BODY — waisted shaft, cavetto collar, parapet wall. Overlaps the foot.\nconst bodyProfile = [\n  [0, 0.8],\n  [4.8, 0.8],\n  [4.4, 3.0],\n  [3.7, 4.5],\n  [3.45, 7.0],\n  [3.4, 10.0],\n  [3.5, 12.2],\n  [3.7, 13.0],\n  [4.9, 13.7],\n  [5.0, 14.2],\n  [5.0, 16.6],\n  [0, 16.6],\n];\nconst body = label(\n  Manifold.revolve(CrossSection.ofPolygons([bodyProfile]), segments),\n  'rook',\n);\n\nconst solid = foot.add(body);\n\n// 3. HOLLOW INTERIOR — labelled 'rook' so bore walls render ivory.\nconst interiorProfile = [\n  [0, 1.6],\n  [2.9, 1.6],\n  [2.7, 7.0],\n  [2.55, 12.0],\n  [2.8, 13.2],\n  [3.4, 14.2],\n  [3.4, 17.2],\n  [0, 17.2],\n];\nconst interior = label(\n  Manifold.revolve(CrossSection.ofPolygons([interiorProfile]), segments),\n  'rook',\n);\nconst hollowBody = solid.subtract(interior);\n\n// 4. CRENELLATIONS — 5 crenels (36° each); cut tools labelled 'rook'.\nconst numCrenels = 5;\nconst gapDeg = 360 / (numCrenels * 2);\nconst gapRad = (gapDeg * Math.PI) / 180;\n\nconst cutBottomZ = 15.0;\nconst cutH = (16.6 - cutBottomZ) + 0.2;\nconst parapetOuterR = 5.0;\nconst radialInner = 2.8;\nconst radialOuter = 6.5;\nconst radialDepth = radialOuter - radialInner;\nconst arcWidth = 2 * parapetOuterR * Math.sin(gapRad / 2);\n\nconst crenelCuts = [];\nfor (let i = 0; i < numCrenels; i++) {\n  const angle = (i * 360) / numCrenels;\n  const block = label(\n    Manifold.cube([radialDepth, arcWidth, cutH])\n    .translate([radialInner, -arcWidth / 2, cutBottomZ - 0.1])\n    .rotate([0, 0, angle]),\n    'rook',\n  );\n  crenelCuts.push(block);\n}\n\nconst rook = hollowBody.subtract(Manifold.union(crenelCuts));\nreturn rook;\n",
