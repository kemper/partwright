      "index": 1,
      "code": "// Butt hinge — two flat leaves, three interlocking knuckles, continuous pin.\n// Laid flat (open 180°). Pin axis along Y, leaves on the XY plane.\n//\n// Dimensions:\n//   Leaf:   30 (X, from knuckle out) × 60 (Y) × 3 (Z thickness).\n//   Knuckle: 8 mm OD, centered on Y axis at z = 4 (so bottom touches z=0).\n//   Pin:    4 mm OD, runs through all knuckles + 1 mm cap each end.\n//   Leaves are centered vertically at z = 4 (matching pin axis), so leaf\n//     bottom = 2.5, top = 5.5. The knuckle OD (8) extends from z=0 to z=8,\n//     so it cleanly engulfs the leaf edge and fuses (≥ 0.5 mm overlap).\n//\n// Leaves alternate ownership of knuckles:\n//   - Leaf A (+X side): owns the middle 20 mm knuckle (Y ∈ [-10, 10]).\n//   - Leaf B (−X side): owns the two outer 15 mm knuckles (Y ∈ [-30,-15] and [15,30]).\n//\n// Each leaf has two countersunk screw holes (3 mm dia, 0.5 mm top chamfer).\n//\n// IMPORTANT NOTE on primitive placement (caught the hard way):\n//   - `BREP.box([w, d, h])`     → centered in X and Y, but base on Z=0\n//     (so a [30, 60, 3] box spans x∈[-15,15], y∈[-30,30], z∈[0,3]).\n//   - `BREP.cylinder(r, h)`     → centered on X and Y at origin, base on Z=0,\n//     height along +Z.\n//   So neither primitive is fully \"centered at origin\" — both have their\n//   base flush with Z=0. Translate Z explicitly to position them.\n\nconst { BREP } = api;\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\nconst LEAF_W      = 30;   // X span (knuckle-meet → outer edge)\nconst LEAF_L      = 60;   // Y length\nconst LEAF_T      = 3;    // Z thickness\nconst KNUCKLE_R   = 4;    // outer radius (8 mm diameter)\nconst PIN_R       = 2;    // pin radius (4 mm diameter)\nconst PIN_CAP     = 1;    // pin overhang past the knuckle row on each end\n\nconst PIN_Z       = KNUCKLE_R;             // pin axis height (= 4)\nconst LEAF_BOT    = PIN_Z - LEAF_T / 2;    // 2.5\nconst LEAF_TOP    = PIN_Z + LEAF_T / 2;    // 5.5\n\nconst SCREW_R     = 1.5;   // 3 mm screw clearance\nconst SCREW_CSK   = 0.5;   // countersink chamfer\nconst LEAF_FILLET = 1.5;   // outer-corner radius\n\n// One uniform brass label across the whole hinge (leaves + pin). A two-tone\n// leaf/pin split doesn't resolve cleanly through the fused knuckles, so we\n// keep a single label for crisp, even color.\nconst BRASS = '#b5894e';\n\n// Knuckle ranges along Y. Outer 15 mm each, middle 20 mm.\nconst Y_OUT_L_MIN = -30, Y_OUT_L_MAX = -15;\nconst Y_MID_MIN   = -10, Y_MID_MAX   =  10;\nconst Y_OUT_R_MIN =  15, Y_OUT_R_MAX =  30;\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\n// A knuckle is a cylinder along Y. BREP.cylinder is base-at-z=0, axis +Z.\n// rotate(-90, X) sends +Z → +Y, so a cylinder of height `len` becomes a\n// horizontal cylinder spanning y∈[0, len], cross-section centered at the\n// origin in XZ. We then translate so its axis sits at (x=0, z=PIN_Z) and\n// y∈[yMin, yMax].\nfunction knuckle(yMin, yMax) {\n  const len = yMax - yMin;\n  return BREP.cylinder(KNUCKLE_R, len)\n    .rotate(-90, [1, 0, 0])\n    .translate([0, yMin, PIN_Z]);\n}\n\n// A leaf slab. xSign = +1 (+X) or −1 (−X). Pre-translate, the [LEAF_W,\n// LEAF_L, LEAF_T] box spans x∈[-LEAF_W/2, LEAF_W/2], y∈[-LEAF_L/2, LEAF_L/2],\n// z∈[0, LEAF_T]. We translate it so:\n//   - X: outer edge at xSign*LEAF_W, inner edge at x=0 (knuckle line).\n//   - Z: spans [LEAF_BOT, LEAF_TOP] (vertically centered on the pin axis).\nfunction leafSlab(xSign) {\n  return BREP.box([LEAF_W, LEAF_L, LEAF_T])\n    .translate([xSign * LEAF_W / 2, 0, LEAF_BOT]);\n}\n\n// Screw hole: a cylinder running through the leaf thickness with 0.5 mm\n// overshoot on top and bottom so the cut is clean on both faces.\nfunction screwHole(x, y) {\n  const overshoot = 0.5;\n  return BREP.cylinder(SCREW_R, LEAF_T + 2 * overshoot)\n    .translate([x, y, LEAF_BOT - overshoot]);\n}\n\n// ---------------------------------------------------------------------------\n// Build one leaf: slab + owned knuckle(s) → fillet outer corners → cut\n// screw holes → chamfer the top rim of each hole.\n//\n// Rule learned from replicad.md: apply fillet BEFORE boolean cuts when\n// possible, so the fillet solver sees a clean edge graph.\n// ---------------------------------------------------------------------------\nfunction buildLeaf(xSign, ownedKnuckles) {\n  const slab = leafSlab(xSign);\n  const fused = BREP.fuseAll([slab, ...ownedKnuckles]);\n\n  // Fillet only the two outer vertical corners of the leaf (far-X end,\n  // both Y extremes). `inDirection: [0,0,1]` picks vertical edges only;\n  // `minX`/`maxX` restricts to the leaf's outer free edge so we don't\n  // touch the knuckle ring or the inner (x=0) seam edges.\n  const outerX = xSign * LEAF_W;\n  const filleted = (xSign > 0)\n    ? fused.fillet(LEAF_FILLET, { inDirection: [0, 0, 1], minX: outerX - 0.5 })\n    : fused.fillet(LEAF_FILLET, { inDirection: [0, 0, 1], maxX: outerX + 0.5 });\n\n  // Screw holes: two per leaf at roughly ±20 mm along Y, 65% out along X.\n  const xHole = xSign * (LEAF_W * 0.65);\n  const drilled = BREP.cutAll([\n    filleted,\n    screwHole(xHole, -20),\n    screwHole(xHole,  20),\n  ]);\n\n  // Countersink: chamfer the top rim of each screw hole. Pick the edges\n  // by `nearPoint` (centered on the hole top, z=LEAF_TOP) + a tight\n  // `withinDist` just larger than the hole radius — that uniquely\n  // identifies the top circle of each hole.\n  return drilled\n    .chamfer(SCREW_CSK, {\n      nearPoint: [xHole, -20, LEAF_TOP],\n      withinDist: SCREW_R + 0.2,\n    })\n    .chamfer(SCREW_CSK, {\n      nearPoint: [xHole,  20, LEAF_TOP],\n      withinDist: SCREW_R + 0.2,\n    });\n}\n\n// ---------------------------------------------------------------------------\n// Build all knuckles and assign ownership.\n// ---------------------------------------------------------------------------\nconst knuckleMid    = knuckle(Y_MID_MIN,   Y_MID_MAX);     // Leaf A owns\nconst knuckleOuterL = knuckle(Y_OUT_L_MIN, Y_OUT_L_MAX);   // Leaf B owns\nconst knuckleOuterR = knuckle(Y_OUT_R_MIN, Y_OUT_R_MAX);   // Leaf B owns\n\n// One uniform 'hinge' label across both leaves (and the pin below).\nconst leafA = BREP.label(buildLeaf(+1, [knuckleMid]), 'hinge', { color: BRASS });\nconst leafB = BREP.label(buildLeaf(-1, [knuckleOuterL, knuckleOuterR]), 'hinge', { color: BRASS });\n\n// ---------------------------------------------------------------------------\n// Pin: runs through all knuckles plus 1 mm cap each end.\n// Total pin length = (Y_OUT_R_MAX - Y_OUT_L_MIN) + 2*PIN_CAP = 60 + 2 = 62.\n// ---------------------------------------------------------------------------\nconst pinLen = (Y_OUT_R_MAX - Y_OUT_L_MIN) + 2 * PIN_CAP;\nconst pin = BREP.label(\n  BREP.cylinder(PIN_R, pinLen)\n    .rotate(-90, [1, 0, 0])\n    .translate([0, Y_OUT_L_MIN - PIN_CAP, PIN_Z]),\n  'hinge',\n  { color: BRASS },\n);\n\n// ---------------------------------------------------------------------------\n// Final assembly. Fuse everything — the two leaves interlock through the\n// knuckles, and the pin runs through all three. Because the leaves don't\n// physically touch each other (the knuckle Y ranges are tiled with the pin\n// providing the only connection), the fuse may yield componentCount = 2\n// (hinge body + pin) or 1 (pin fuses leaves together via the knuckle bores)\n// depending on how OCCT resolves the touching cylinders. Either is correct\n// for a real hinge.\n// ---------------------------------------------------------------------------\nreturn BREP.fuseAll([leafA, leafB, pin]);\n",
