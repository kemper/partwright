      "index": 1,
      "code": "const { Manifold, CrossSection, label } = api;\n\n// Helper: axis-aligned box from min/max corners\nfunction box(min, max) {\n  const s = [max[0] - min[0], max[1] - min[1], max[2] - min[2]];\n  const c = [(min[0] + max[0]) / 2, (min[1] + max[1]) / 2, (min[2] + max[2]) / 2];\n  return Manifold.cube(s, true).translate(c);\n}\n\n// Main 16-unit cube body\nconst body = Manifold.cube([16, 16, 16], true);\n\n// === HEART SHAPE ===\n// Build a blocky heart out of raised cuboids on each face.\n// Heart pixel art (5-wide, 5-tall grid, each pixel = 2 units):\n//  .XX.XX.   row4 (top) — two bumps\n//  XXXXXXX   row3\n//  XXXXXXX   row2\n//  .XXXXX.   row1\n//  ..XXX..   row0\n//  ...X...   row-1 (point)\n// Center at x=0, z=0; protrudes 1.2 units out from face, overlaps 0.5\n\n// Front face heart (protruding toward -Y)\nconst fhy = [-8.7, -7.5]; // front protrusion with 0.5 overlap\nfunction fhp(x0, x1, z0, z1) {\n  return box([x0, fhy[0], z0], [x1, fhy[1], z1]);\n}\n// Heart shape: two bumps at top, wide middle, tapers to point\nconst heartFront =\n  fhp(-4, -1, 2.5, 5) // left bump top\n  .add(fhp(1, 4, 2.5, 5)) // right bump top\n  .add(fhp(-5, 5, 0.5, 3)) // wide middle\n  .add(fhp(-4, 4, -1.5, 1)) // upper taper\n  .add(fhp(-3, 3, -3.5, -1)) // middle taper\n  .add(fhp(-1, 1, -5.5, -3)); // point at bottom\n\n// Back face heart (protruding toward +Y)\nconst bhy = [7.5, 8.7];\n\nfunction bhp(x0, x1, z0, z1) {\n  return box([x0, bhy[0], z0], [x1, bhy[1], z1]);\n}\nconst heartBack =\n  bhp(-4, -1, 2.5, 5)\n  .add(bhp(1, 4, 2.5, 5))\n  .add(bhp(-5, 5, 0.5, 3))\n  .add(bhp(-4, 4, -1.5, 1))\n  .add(bhp(-3, 3, -3.5, -1))\n  .add(bhp(-1, 1, -5.5, -3));\n\n// Left face heart (protruding toward -X)\nconst lhx = [-8.7, -7.5];\n\nfunction lhp(y0, y1, z0, z1) {\n  return box([lhx[0], y0, z0], [lhx[1], y1, z1]);\n}\nconst heartLeft =\n  lhp(-4, -1, 2.5, 5)\n  .add(lhp(1, 4, 2.5, 5))\n  .add(lhp(-5, 5, 0.5, 3))\n  .add(lhp(-4, 4, -1.5, 1))\n  .add(lhp(-3, 3, -3.5, -1))\n  .add(lhp(-1, 1, -5.5, -3));\n\n// Right face heart (protruding toward +X)\nconst rhx = [7.5, 8.7];\n\nfunction rhp(y0, y1, z0, z1) {\n  return box([rhx[0], y0, z0], [rhx[1], y1, z1]);\n}\nconst heartRight =\n  rhp(-4, -1, 2.5, 5)\n  .add(rhp(1, 4, 2.5, 5))\n  .add(rhp(-5, 5, 0.5, 3))\n  .add(rhp(-4, 4, -1.5, 1))\n  .add(rhp(-3, 3, -3.5, -1))\n  .add(rhp(-1, 1, -5.5, -3));\n\nconst hearts = heartFront.add(heartBack).add(heartLeft).add(heartRight);\n\n// === EDGE BARS ===\n// Raised bars along each of the 12 cube edges, 1.5 wide × 1 tall, full length\n// 4 vertical edges (along Z)\nconst ev = 1.5; // edge bar half-width\nconst et = 1.0; // edge bar protrusion thickness\nconst eL = 16; // full cube edge length\n\n// Corner positions at ±8, bar spans full length of edge\n// Vertical edges — run along Z\nfunction vEdgeBar(sx, sy) {\n  // Centered on the corner at (sx*8, sy*8), runs z = -8..8\n  return box([sx * 8 - et, sy * 8 - et, -8], [sx * 8 + et, sy * 8 + et, 8]);\n}\n\n// Horizontal edges along X\nfunction hxEdgeBar(sy, sz) {\n  return box([-8, sy * 8 - et, sz * 8 - et], [8, sy * 8 + et, sz * 8 + et]);\n}\n\n// Horizontal edges along Y\nfunction hyEdgeBar(sx, sz) {\n  return box([sx * 8 - et, -8, sz * 8 - et], [sx * 8 + et, 8, sz * 8 + et]);\n}\n\nconst edgeBars =\n  // 4 vertical edges\n  vEdgeBar(-1, -1).add(vEdgeBar(1, -1)).add(vEdgeBar(-1, 1)).add(vEdgeBar(1, 1))\n  // 4 edges along X (top and bottom)\n  .add(hxEdgeBar(-1, -1)).add(hxEdgeBar(1, -1))\n  .add(hxEdgeBar(-1, 1)).add(hxEdgeBar(1, 1))\n  // 4 edges along Y (front/back at top and bottom)\n  .add(hyEdgeBar(-1, -1)).add(hyEdgeBar(1, -1))\n  .add(hyEdgeBar(-1, 1)).add(hyEdgeBar(1, 1));\n\nreturn label(body, 'body')\n  .add(label(hearts, 'hearts'))\n  .add(label(edgeBars, 'edges'));\n",
