      "index": 1,
      "code": "// Precision L-bracket — BREP/replicad showcase\n// Two legs forming an L, with selective fillets:\n//   • inside concave web (where the legs meet) filleted 5 mm — the signature\n//   • outside tip edges of each leg's free end, rounded 2.5 mm\n// All rounding applied BEFORE drilling mounting holes (per replicad.md).\nconst { BREP } = api;\n\n// Dimensions\nconst LEG_LEN = 60;     // length of each leg from the corner\nconst WIDTH   = 50;     // depth (Y) of the bracket\nconst THICK   = 6;      // wall thickness\n\n// BREP.box is centred on the Z axis in X & Y but has its base on Z=0\n// (X & Y from -size/2 to +size/2, Z from 0 to size.z). Translate in X only\n// to push each box's corner from the origin's X=-half to X=0.\n// After this, horizLeg lives in X[0..LEG_LEN], Y[-W/2..W/2], Z[0..THICK].\nconst horizLeg = BREP.label(\n  BREP.box([LEG_LEN, WIDTH, THICK]).translate([LEG_LEN / 2, 0, 0]),\n  'bracket',\n  { color: '#16a085' },\n);\n\n// And vertLeg lives in X[0..THICK], Y[-W/2..W/2], Z[0..LEG_LEN].\nconst vertLeg = BREP.label(\n  BREP.box([THICK, WIDTH, LEG_LEN]).translate([THICK / 2, 0, 0]),\n  'bracket',\n  { color: '#16a085' },\n);\n\n// Fuse into the L. The corner cube (THICK × WIDTH × THICK) is shared —\n// replicad merges the coplanar inside faces, leaving a clean L-prism.\nlet bracket = horizLeg.fuse(vertLeg);\n\n// --- Selective fillets, applied BEFORE any cuts. ---\n// Every edge we care about is parallel to +Y. Combining `inDirection`\n// with one axis-range filter reliably picks each one.\nconst Y_DIR = [0, 1, 0];\n\n// 1. THE signature feature: inside concave web edge at (X=THICK, Z=THICK).\n//    Pick by nearPoint at the edge midpoint.\nbracket = bracket.fillet(5, {\n  nearPoint: [THICK, 0, THICK],\n  withinDist: 1,\n});\n\n// 2. Outside tip of the horizontal leg — Y-parallel edge at X=LEG_LEN, Z=0.\n//    Only Y-parallel edge with Z≤0 on the L (the inside-bottom corner is\n//    absorbed because both legs touch Z=0 along the same face).\nbracket = bracket.fillet(2.5, {\n  inDirection: Y_DIR,\n  maxZ: 0.01,\n});\n\n// 3. Outside tip of the vertical leg — Y-parallel edge at X=0, Z=LEG_LEN.\n//    Only Y-parallel edge with X≤0.\nbracket = bracket.fillet(2.5, {\n  inDirection: Y_DIR,\n  maxX: 0.01,\n});\n\n// --- Mounting holes (drilled AFTER all rounding). ---\nconst HOLE_R = 2.5;            // 5 mm diameter\nconst HOLE_INSET_AXIAL = 15;   // distance along the leg from the free end\nconst HOLE_INSET_Y     = 12;   // distance from each Y face\n\nconst holes = [];\n\n// Horizontal leg: drill top-down (default Z-axis cylinder).\n// Cylinder is also centered at origin in XY but with base at z=0, height +Z.\n// Actually BREP.cylinder(r, h) — base on XY, height along +Z. Centered on Z axis.\nfor (const y of [-WIDTH / 2 + HOLE_INSET_Y, WIDTH / 2 - HOLE_INSET_Y]) {\n  holes.push(\n    BREP.cylinder(HOLE_R, THICK + 2)\n      .translate([LEG_LEN - HOLE_INSET_AXIAL, y, -1])\n  );\n}\n\n// Vertical leg: drill horizontally through THICK. Rotate cylinder +90°\n// about Y so its axis points along +X.\nfor (const y of [-WIDTH / 2 + HOLE_INSET_Y, WIDTH / 2 - HOLE_INSET_Y]) {\n  holes.push(\n    BREP.cylinder(HOLE_R, THICK + 2)\n      .rotate(90, [0, 1, 0])\n      .translate([-1, y, LEG_LEN - HOLE_INSET_AXIAL])\n  );\n}\n\nreturn BREP.cutAll([bracket, ...holes]);\n",
