      "index": 1,
      "code": "// Quad Spiral Spire — a tall four-start print-in-place spiral cone. Four\n// interleaved helical blades screw apart. componentCount === 4 (arms).\n// Steep helix + central bore keep the four blades independent on the print;\n// each sweeps to its own sharp point. Treat 1 unit ≈ 1 mm.\nconst { Manifold, CrossSection } = api;\nconst p = api.params({\n  arms:      { type: 'int',    default: 4,   min: 2,   max: 5,   step: 1,   label: 'Spiral arms' },\n  baseR:     { type: 'number', default: 13,  min: 8,   max: 24,  step: 0.5, unit: 'mm', label: 'Base radius' },\n  height:    { type: 'number', default: 64,  min: 28,  max: 95,  step: 1,   unit: 'mm', label: 'Height' },\n  turns:     { type: 'number', default: 2.3, min: 1,   max: 5,   step: 0.1, label: 'Spiral turns (fewer = steeper)' },\n  clearance: { type: 'number', default: 0.5, min: 0.3, max: 1.2, step: 0.05, unit: 'mm', label: 'Print clearance' },\n  coreFrac:  { type: 'number', default: 0.32, min: 0,  max: 0.6, step: 0.02, label: 'Central bore (× base R)' },\n});\nconst palette = ['#ef4444', '#f5b324', '#22c55e', '#7c3aed', '#0ea5e9'];\nconst R = p.baseR, H = p.height, arms = p.arms, clr = p.clearance;\nconst tipR = Math.max(0.5, R * 0.03);          // truncate apex so it resolves, not a stalk\nconst sTop = tipR / R;                          // shared taper rate for body + bore\n// Smooth cone body — every spiral comes from the cuts, so the surface stays clean.\nlet body = CrossSection.circle(R, 140).extrude(H, 160, 0, sTop);\n// Tapered central bore: removes the dense near-axis zone where the blades would\n// otherwise fuse on the print, and leaves a wall of constant proportion to the tip.\nconst boreR = R * p.coreFrac;\nif (boreR > 0.4) body = body.subtract(\n  CrossSection.circle(boreR, 96).extrude(H + 2, 140, 0, sTop).translate([0, 0, -1]));\n// N radial helical slab cutters. Each is a constant-thickness gap (= clr) so the\n// clearance stays printable at every height while the cone narrows; that also makes\n// each blade pinch to its own sharp point near the top. Fewer turns = steeper helix\n// = each blade's plastic stays in its own lane and won't bond to its neighbour.\nconst ov = boreR + 1.5;\nconst slab2d = CrossSection.square([R + 6 + ov, clr], false).translate([-ov, -clr / 2]);\nconst baseCut = slab2d.extrude(H + 8, 340, 360 * p.turns, 1).translate([0, 0, -4]);\nlet cut = baseCut;\nfor (let k = 1; k < arms; k++) cut = cut.add(baseCut.rotate([0, 0, (k * 360) / arms]));\nconst parts = body.subtract(cut).decompose();      // -> componentCount === arms\nreturn api.labeledUnion(parts.map((s, i) => ({ name: 'arm' + i, shape: s, color: palette[i % palette.length] })));\n",
