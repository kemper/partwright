      "index": 1,
      "code": "// Geodesic Lantern — elegant antique faceted dome lantern\n// v22: Open base for tea-light/LED candle — hollow interior, ring foot\n\nconst { Manifold, CrossSection } = api;\n\n// === PROPORTIONS ===\nconst RXY    = 13.0;   // outer dome equatorial radius (26mm wide)\nconst RZ     = 20.0;   // outer dome height (taller than wide)\nconst WALL_T = 2.0;    // shell wall thickness\nconst SEGS   = 16;     // low poly = geodesic faceting look\n\n// Dome clipped flat at Z=0 (equatorial cut)\nconst DOME_BASE_Z = 0.0;\n\n// Inner cavity radii\nconst IRX = RXY - WALL_T;  // 11mm\nconst IRZ = RZ  - WALL_T;  // 18mm\n\n// === COLORS ===\nconst C_FRAME  = '#a87040';   // warm medium bronze\nconst C_BASE   = '#6b4422';   // dark rich base\nconst C_FINIAL = '#e6b820';   // bright gold\n\n// ========================================================\n// STEP 1: Outer ellipsoid shell — cut flat at Z=0\n// ========================================================\nconst BIG = RXY * 6;\n\nconst outerEgg = Manifold.sphere(1, SEGS).scale([RXY, RXY, RZ]);\nconst innerEgg = Manifold.sphere(1, SEGS).scale([IRX, IRX, IRZ]);\n\nconst aboveZero = Manifold.cube([BIG, BIG, RZ * 2 + 10], false)\n  .translate([-BIG/2, -BIG/2, DOME_BASE_Z]);\n\nlet domeShell = outerEgg.intersect(aboveZero)\n  .subtract(innerEgg.intersect(aboveZero));\n\n// ========================================================\n// STEP 2: Window cutters — bidirectional, guaranteed through-wall\n// ========================================================\nfunction windowCutter(zAbs, wRadius) {\n  const halfLen = RXY + 5.0;\n  return Manifold.cylinder(halfLen * 2, wRadius, wRadius, 20, false)\n    .rotate([0, 90, 0])\n    .translate([-halfLen, 0, zAbs]);\n}\n\nfunction windowRing(zAbs, wRadius, count, offsetDeg) {\n  let ring = null;\n  for (let i = 0; i < count; i++) {\n    const az = (360 / count) * i + offsetDeg;\n    const c = windowCutter(zAbs, wRadius).rotate([0, 0, az]);\n    ring = ring ? ring.add(c) : c;\n  }\n  return ring;\n}\n\n// Lower ring at Z=6.5, upper at Z=11 (offset 30°)\nconst lowerRing = windowRing(6.5,  2.6, 6, 0);\nconst upperRing = windowRing(11.0, 2.1, 6, 30);\n\ndomeShell = domeShell.subtract(lowerRing).subtract(upperRing);\n\n// ========================================================\n// STEP 3: Raised decorative banding ring between window rows\n// ========================================================\nconst BAND_Z      = 8.75;\nconst bandDomeFrac = 8.75 / RZ;\nconst bandDomeR   = RXY * Math.sqrt(1 - bandDomeFrac * bandDomeFrac);\n\nconst BAND_RO = bandDomeR + 0.8;\nconst BAND_RI = bandDomeR - 0.5;\nconst BAND_H  = 1.8;\nconst bandRing = CrossSection.circle(BAND_RO, 32)\n  .subtract(CrossSection.circle(BAND_RI, 32))\n  .extrude(BAND_H)\n  .translate([0, 0, BAND_Z - BAND_H / 2]);\n\ndomeShell = domeShell.add(bandRing);\n\nconst framePart = api.label(domeShell, 'frame', { color: C_FRAME });\n\n// ========================================================\n// STEP 4: Open ring base — hexagonal ring foot, hollow center\n// Allows placing a tea light or LED votive inside from below.\n// The dome's hollow interior (inner egg subtracted) is now\n// accessible through the open center of the ring base.\n// ========================================================\nconst BASE_H = 3.5;\nconst BASE_R = RXY + 1.2;     // outer radius matches dome shoulder\nconst BASE_INNER_R = BASE_R - 2.0;  // inner opening (large enough for candle access)\nconst BASE_Z = DOME_BASE_Z - BASE_H;\n\n// Hexagonal ring: outer hex minus inner circle (stability + open bottom)\nconst hexBase = CrossSection.circle(BASE_R, 6)\n  .subtract(CrossSection.circle(BASE_INNER_R, 24))\n  .extrude(BASE_H)\n  .translate([0, 0, BASE_Z]);\n\n// Collar: narrow annular ring connecting base to dome (same as before)\nconst COLL_RO = RXY + 0.6;\nconst COLL_RI = RXY - 1.0;\nconst COLL_H  = 1.5;\nconst collar = CrossSection.circle(COLL_RO, 24)\n  .subtract(CrossSection.circle(COLL_RI, 24))\n  .extrude(COLL_H)\n  .translate([0, 0, DOME_BASE_Z - COLL_H]);\n\nconst basePart = api.label(hexBase.add(collar), 'base', { color: C_BASE });\n\n// ========================================================\n// STEP 5: Gold finial at apex\n// ========================================================\nconst APEX_Z = RZ;\n\nconst finStem  = Manifold.cylinder(3.5, 1.2, 1.2, 16)\n  .translate([0, 0, APEX_Z - 1.0]);\n\nconst BEAD_R   = 2.0;\nconst BEAD_Z   = APEX_Z + 2.5;\nconst finBead  = Manifold.sphere(BEAD_R, 18)\n  .translate([0, 0, BEAD_Z]);\n\nconst SPIRE_Z  = BEAD_Z + BEAD_R * 0.9;\nconst finSpire = Manifold.cylinder(12.0, BEAD_R * 0.6, 0.2, 16)\n  .translate([0, 0, SPIRE_Z]);\n\nconst finialPart = api.label(\n  finStem.add(finBead).add(finSpire),\n  'finial', { color: C_FINIAL }\n);\n\n// ========================================================\n// STEP 6: Assemble — three labeled pieces, one manifold\n// ========================================================\nreturn framePart.add(basePart).add(finialPart);\n",
