      "index": 1,
      "code": "// Voxel Knight — a chibi heroic knight standing on the ground.\n// Symmetric about x=0 for the body (build +x half, mirror) — but the SHIELD\n// (left side, -x) and SWORD (right side, +x) are asymmetric, so they're added\n// AFTER the mirror. FACE / front features on +Y so they face the catalog\n// 3/4 camera. Z-up, feet sit on z=0.\nconst { voxels } = api;\nconst v = voxels();\n\n// ---- palette ----\nconst STEEL    = '#a9b6c4';  // main armor steel\nconst STEEL_D  = '#76828f';  // shadow steel (outer side walls)\nconst STEEL_L  = '#d2dbe4';  // highlight steel (tops / bevels)\nconst STEEL_DD = '#59636e';  // deep shadow / joints\nconst GOLD     = '#f2c14e';  // gold trim\nconst GOLD_D   = '#c9952c';  // gold shadow\nconst RED      = '#d6332e';  // plume / shield emblem\nconst RED_L    = '#f0584f';  // plume highlight\nconst RED_D    = '#a3221f';  // plume shadow\nconst DARK     = '#222a31';  // visor slit / inner shadow\nconst SKIN     = '#e8b98f';  // a hint of face inside the visor (eyes glint)\nconst EYE      = '#8fd0ff';  // eye glint\nconst WOOD     = '#7a4a26';  // sword grip\nconst BLADE    = '#cfd6dc';  // sword blade\nconst BLADE_L  = '#eef2f5';  // blade highlight\n\n// FRONT = max Y. Body roughly spans y: -3..3; front face at y=3, decorations\n// poke to y=4 (+Y). Build the +x half then mirror across x.\n\n// ======== LEGS / BOOTS ========\n// +x leg, x:1..3.\nv.fillBox([1, -2, 0], [3, 2, 1], STEEL_DD);    // boot sole (dark)\nv.fillBox([1, -2, 1], [3, 2, 2], DARK);        // boot body\nv.fillBox([1, -3, 1], [3, -3, 2], STEEL_DD);   // boot toe poking forward (+Y)\nv.fillBox([1, -2, 3], [3, 2, 7], STEEL);       // greave (leg armor)\nv.fillBox([3, -2, 3], [3, 2, 7], STEEL_D);     // outer leg shadow\nv.set(2, -3, 5, GOLD);                          // gold knee stud (front)\n\n// ======== TORSO / CUIRASS ========\nv.fillBox([0, -3, 8], [4, 3, 15], STEEL);       // chest plate\nv.fillBox([4, -3, 8], [4, 3, 15], STEEL_D);     // outer side shadow\nv.fillBox([0, -3, 15], [4, 3, 15], STEEL_L);    // top bevel highlight\nv.fillBox([0, -3, 8], [4, 3, 8], STEEL_DD);     // waist shadow line\n// gold trim down the breastplate center (front, +Y)\nv.set(0, -4, 9, GOLD); v.set(0, -4, 10, GOLD);\nv.set(0, -4, 13, GOLD); v.set(0, -4, 14, GOLD);\n// chest emblem accent (gold boss)\nv.set(1, -4, 12, GOLD); v.set(0, -4, 12, GOLD_D);\n// belt\nv.fillBox([0, -4, 8], [4, -4, 8], GOLD_D);\n\n// ======== PAULDRONS (shoulder armor) ========\nv.fillBox([3, -3, 15], [5, 3, 16], STEEL_L);    // pauldron top (catches light)\nv.fillBox([3, -3, 14], [6, 3, 15], STEEL);      // pauldron body\nv.fillBox([6, -3, 14], [6, 3, 15], STEEL_D);    // pauldron outer shadow\nv.fillBox([3, -4, 14], [6, -4, 16], GOLD_D);    // pauldron gold rim (front)\nv.set(6, -4, 15, GOLD);                          // pauldron spike-ish stud\n\n// ======== ARMS ========\nv.fillBox([5, -2, 9], [6, 2, 13], STEEL);       // upper arm\nv.fillBox([6, -2, 9], [6, 2, 13], STEEL_D);     // arm outer shadow\nv.fillBox([5, -2, 9], [6, 2, 9], STEEL_DD);     // elbow joint\nv.fillBox([5, -2, 6], [6, 2, 8], STEEL);        // forearm / gauntlet\nv.set(5, -3, 11, GOLD);                          // arm trim (front)\n\n// ======== NECK / GORGET ========\nv.fillBox([0, -2, 16], [2, 2, 16], STEEL_DD);   // gorget (neck guard)\n\n// ======== HELMET ========\nv.fillBox([0, -3, 17], [4, 3, 22], STEEL);      // helm body\nv.fillBox([4, -3, 17], [4, 3, 22], STEEL_D);    // helm side shadow\nv.fillBox([0, -3, 22], [4, 3, 22], STEEL_L);    // helm crown highlight\nv.fillBox([0, -3, 17], [4, 3, 17], STEEL_DD);   // helm base shadow\n// visor: dark band across the front (+Y), with a slit\nv.fillBox([0, -4, 18], [4, -4, 21], STEEL_D);   // visor face plate (front)\nv.fillBox([0, -4, 19], [4, -4, 20], DARK);      // dark visor slit (the eye band)\n// eyes glinting inside the slit\nv.set(1, -4, 20, EYE);\nv.set(2, -4, 20, SKIN);\n// gold brow trim above the visor\nv.fillBox([0, -4, 21, ], [3, -4, 21], GOLD);\n// cheek / jaw rivets\nv.set(3, -4, 18, GOLD_D);\n\n// ======== PLUME / CREST (red) ========\n// A red crest running front-to-back along the top center of the helm.\n// Centered on x=0 so it survives the mirror cleanly.\nv.fillBox([0, -2, 23], [0, 2, 23], RED);        // crest base ridge\nv.fillBox([0, -2, 24], [0, 1, 24], RED_L);      // crest highlight row\nv.fillBox([0, 0, 25], [0, 2, 25], RED);         // crest rises toward back\nv.set(0, 2, 24, RED_D);                          // back shadow\nv.set(0, -2, 24, RED_L);                         // front tip highlight\nv.set(0, -3, 23, RED_D);                         // a forward-drooping front tuft\n\n// ======== mirror the symmetric body across x ========\nv.mirror('x');\n\n// ================================================================\n// ASYMMETRIC PROPS (added AFTER mirror so they stay one-sided)\n// ================================================================\n\n// -------- SHIELD on the LEFT arm (-x side) --------\n// A heater-style shield held forward (+Y), face plate at y=-5 (toward camera).\nconst sx1 = -7;   // shield front-face column x\n// Shield face plate (front, y=-5), heater outline.\n// Rows top->bottom, narrowing near the bottom point.\nconst shieldRows = [\n  // [z, yspan-from, yspan-to]\n  [15, -3, 3],\n  [14, -3, 3],\n  [13, -3, 3],\n  [12, -3, 3],\n  [11, -2, 2],\n  [10, -1, 1],\n  [9, 0, 0],\n];\nfor (const [z, ya, yb] of shieldRows) {\n  v.fillBox([sx1, ya, z], [sx1, yb, z], STEEL);          // shield field\n  v.fillBox([sx1 - 1, ya, z], [sx1 - 1, yb, z], STEEL_D); // shield back shadow\n  // front rim (+Y outer column) gold\n}\n// gold border around the shield (top edge + sides)\nv.fillBox([sx1, -3, 15], [sx1, 3, 15], GOLD);            // top gold band\nv.set(sx1, -3, 14, GOLD); v.set(sx1, 3, 14, GOLD);\nv.set(sx1, -3, 13, GOLD); v.set(sx1, 3, 13, GOLD);\nv.set(sx1, -2, 12, GOLD); v.set(sx1, 2, 12, GOLD);\n// red emblem: a CROSS on the shield\nv.set(sx1, 0, 14, RED); v.set(sx1, 0, 13, RED); v.set(sx1, 0, 12, RED); v.set(sx1, 0, 11, RED); // vertical\nv.set(sx1, -1, 13, RED); v.set(sx1, 1, 13, RED);  // horizontal arms\nv.set(sx1, 0, 13, RED_L);                          // cross center highlight\n// shield boss center already red; darken back rim\nv.set(sx1 - 1, 0, 13, STEEL_DD);\n// strap arm connection (steel) linking shield to the body\nv.fillBox([-6, -1, 11], [-5, 1, 13], STEEL_D);\n\n// -------- SWORD on the RIGHT arm (+x side) --------\n// Held upright, blade pointing up, on the +x side near the gauntlet.\nconst wx = 7;   // sword column x\n// grip\nv.fillBox([wx, -3, 7], [wx, -3, 9], WOOD);              // grip (in the hand, front)\n// pommel (gold) at the base\nv.set(wx, -3, 6, GOLD);\n// crossguard (gold) — spans across in X a bit and Y\nv.fillBox([wx - 1, -3, 10], [wx + 1, -3, 10], GOLD);\nv.set(wx, -4, 10, GOLD_D);\n// blade rising up\nv.fillBox([wx, -3, 11], [wx, -3, 20], BLADE);\nv.fillBox([wx, -4, 11], [wx, -4, 20], BLADE_L);         // blade front highlight edge\nv.set(wx, -3, 21, BLADE_L);                             // blade tip\nv.set(wx, -3, 20, BLADE_L);\n// fuller (center groove) shadow\nv.set(wx, -3, 15, STEEL_D);\n\nreturn v;\n",
