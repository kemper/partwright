      "index": 1,
      "code": "// Voxel Robot — a boxy retro robot character standing on the ground.\n// Symmetric about x=0 (build +x half, mirror). FACE features on -Y so they\n// face the catalog 3/4 camera (which looks toward +Y/+X). Z-up, sits on z=0.\nconst { voxels } = api;\nconst v = voxels();\n\n// ---- palette ----\nconst STEEL   = '#9aa7b4';  // main body steel\nconst STEEL_D = '#6f7d8c';  // shadow steel (outer side walls / +X)\nconst STEEL_L = '#c7d1da';  // highlight steel (tops)\nconst BLUE    = '#3f6fb0';  // accent blue panel\nconst BLUE_D  = '#2c4f80';\nconst DARK    = '#283038';  // face plate / joints\nconst DARK_L  = '#3a444e';\nconst CYAN    = '#3ff0ff';  // glowing eyes\nconst CYAN_L  = '#aef7ff';\nconst RED      = '#ff4444'; // chest light\nconst RED_L    = '#ff8a8a';\nconst YELLOW   = '#ffd23f'; // antenna bobble / buttons\n\n// FRONT = min Y (-Y), facing the camera. Body spans y: -3..3; face decorations\n// poke forward at y=-4.\nfunction box(a, b, c) { v.fillBox(a, b, c); }\n\n// ======== LEGS / FEET ========\n// +x leg, shaft x:1..3, mirror later.\nbox([1, -2, 0], [3, 2, 6], STEEL_D);           // leg shaft (shadowed) — reaches the torso at z7\nbox([1, -2, 5], [3, 2, 6], STEEL);             // knee highlight\n// foot sticks forward (-Y)\nbox([1, -4, 0], [3, 2, 1], DARK);              // foot block (forward)\nbox([1, -4, 1], [3, 2, 1], DARK_L);            // foot top edge\n\n// ======== TORSO ========\nbox([0, -3, 7], [5, 3, 15], STEEL);\nbox([5, -3, 7], [5, 3, 15], STEEL_D);          // outer side shadow\nbox([0, -3, 15], [5, 3, 15], STEEL_L);         // top highlight\n// chest panel (dark plate on front face, y=-4)\nbox([0, -4, 9], [3, -4, 13], DARK);\n// chest light (red, centered, glows)\nv.set(0, -4, 11, RED); v.set(1, -4, 11, RED);\nv.set(0, -4, 12, RED_L);\n// little buttons\nv.set(2, -4, 9, YELLOW);\nv.set(2, -4, 10, CYAN);\nv.set(3, -4, 12, BLUE);\n\n// ======== ARMS ========\nbox([6, -2, 13], [7, 2, 15], STEEL);           // shoulder\nbox([6, -2, 8], [7, 2, 13], STEEL_D);          // upper arm (shadow)\nbox([6, -2, 7], [7, 2, 7], DARK);              // wrist joint\nbox([6, -4, 6], [7, -3, 8], STEEL_L);          // hand poking forward (-Y)\nv.set(6, -4, 7, CYAN);                         // little hand light\n\n// ======== NECK ========\nbox([0, -2, 15], [2, 2, 16], DARK);            // neck (centered)\n\n// ======== HEAD ========\nbox([0, -3, 17], [5, 3, 23], STEEL);\nbox([5, -3, 17], [5, 3, 23], STEEL_D);         // side shadow\nbox([0, -3, 23], [5, 3, 23], STEEL_L);         // top highlight\n// face plate (dark recessed front, y=-4)\nbox([0, -4, 18], [4, -4, 22], DARK);\n// glowing cyan eyes (big square eyes for personality)\nbox([1, -4, 20], [2, -4, 21], CYAN);\nv.set(1, -4, 21, CYAN_L);                       // eye highlight\n// mouth grille — row of bars low on the face\nv.set(0, -4, 18, CYAN);\nv.set(2, -4, 18, CYAN);\nv.set(4, -4, 18, CYAN);\n// side ear knobs\nbox([6, -1, 19], [6, 1, 21], BLUE);\nv.set(6, 0, 20, BLUE_D);\n\n// ======== ANTENNA ========\nv.set(0, 0, 24, DARK);\nv.set(0, 0, 25, STEEL_D);\nv.set(0, 0, 26, STEEL_D);\nv.set(0, 0, 27, YELLOW);                        // glowing bobble\nv.set(0, 0, 28, RED);\n\n// mirror across x to complete the symmetric robot\nv.mirror('x');\n\nreturn v;\n",
