      "index": 1,
      "code": "// Voxel Cat — a cute SITTING orange tabby cat.\n// Symmetric about x=0: build the +x half, mirror across x.\n// Orientation (verified): the -Y face is the front-left the camera sees, the +X\n// face is the right. So all FACE features go on the flat -Y plane (y = front).\n// Z-up, sits on z=0. Silhouette: sitting body -> neck break -> round head -> ears.\nconst { voxels } = api;\nconst v = voxels();\n\n// ---- palette (orange tabby) ----\nconst ORG   = '#f4972f';  // main orange fur\nconst ORG_D = '#d07a1e';  // shadow orange (outer +X side walls)\nconst ORG_L = '#ffb255';  // highlight orange (tops)\nconst STR   = '#9c5316';  // darker tabby stripes\nconst WHT   = '#fdf6ea';  // white muzzle / belly / paws\nconst WHT_D = '#e4dac8';  // shadow white\nconst PINK  = '#ff90ab';  // nose\nconst PINK_D= '#d65071';  // inner ear / mouth\nconst EYE   = '#33b85e';  // green eye\nconst EYE_L = '#9aeeb0';  // eye highlight\nconst BLK   = '#241f1b';  // pupil / detail\n\nfunction box(a, b, c) { v.fillBox(a, b, c); }\n\n// FRONT = min Y. Body front at y=-3, head front (the face plane) at y=-5.\n\n// ============ SITTING BODY ============\n// z0..3 : wide rounded haunch base\nbox([0, -3, 0], [4, 4, 3], ORG);\nbox([4, -3, 0], [4, 4, 3], ORG_D);          // outer +X side shadow\nbox([0, -3, 3], [4, 4, 3], ORG_L);          // base top highlight\nv.remove(4, 4, 0);                           // soften back-bottom corner\n// z4..7 : chest, narrower\nbox([0, -3, 4], [3, 3, 7], ORG);\nbox([3, -3, 4], [3, 3, 7], ORG_D);\nbox([0, -3, 7], [3, 3, 7], ORG_L);\n// z8..10 : slim neck (clearly narrower than head -> the visual break)\n// rises to z10 so it fuses to the head above — a narrow neck still reads\n// as a break, but the head is no longer a floating, unprintable island.\nbox([0, -2, 8], [1, 2, 10], ORG);\nbox([1, -2, 8], [1, 2, 10], ORG_L);\n\n// white chest bib down the front (-Y)\nbox([0, -4, 1], [1, -4, 7], WHT);\nv.set(2, -4, 2, WHT); v.set(2, -4, 3, WHT);\n\n// subtle tabby stripes on the back/side\nv.set(4, 3, 2, STR); v.set(4, 1, 2, STR);\nv.set(3, 2, 5, STR); v.set(3, 0, 6, STR);\n\n// ============ FRONT PAWS ============\nbox([0, -4, 0], [1, -4, 0], WHT);\nbox([3, -4, 0], [3, -4, 0], WHT);\nv.set(2, -4, 0, WHT_D);\nv.set(1, -5, 0, WHT);                        // toes poke forward\nv.set(3, -5, 0, WHT);\n\n// ============ HEAD ============\n// A solid CUBE head, 5 wide (x0..4) x 6 deep (y-5..0) x 6 tall (z11..16).\n// The narrow neck (x0..1) rises into this head at z10..11 -> the head\n// reads as a distinct round mass but stays fused to the body (printable).\n// Front wall = flat plane y=-5 (the face). Keep it a clean cube — only a tiny\n// chamfer on the topmost outer corner so it reads round, not boxy.\nbox([0, -5, 11], [4, 0, 16], ORG);\nbox([4, -5, 11], [4, 0, 16], ORG_D);        // +X side shadow\nbox([0, -5, 16], [4, 0, 16], ORG_L);        // crown highlight\nbox([0, -5, 11], [4, 0, 11], ORG_D);        // shadowed underside (overhang shelf)\n// gentle rounding: trim just the top outer-front corner block\nv.remove(4, -5, 16);\n\n// ---- FACE on the flat front plane y=-5 ----\n// Big bright green eyes, set high-center with a clear bare gap (x0..1) at center.\nbox([2, -5, 13], [3, -5, 14], EYE);         // chunky 2x2 eye (mirrors to a pair)\nv.set(2, -5, 14, EYE_L);                     // bright upper sparkle\nv.set(3, -5, 13, BLK);                       // pupil (lower-outer)\n// white muzzle block lower-center, with pink nose + mouth (all on y=-5)\nbox([0, -5, 11], [2, -5, 12], WHT);         // muzzle (mirrors to a wide pad)\nv.set(0, -5, 12, PINK);                      // nose (center seam -> single)\nv.set(1, -5, 11, PINK_D);                    // mouth\n// whisker dots on the cheeks\nv.set(4, -5, 12, WHT_D);\n// forehead \"M\" tabby stripe just above the eyes\nv.set(0, -5, 15, STR); v.set(2, -5, 15, STR);\n\n// ============ EARS (tall clean triangles, pink inner) ============\n// Two prominent triangle ears sitting ON the visible head-top crown, set back\n// from the front edge (y -3..-2) so they rise clearly against the sky in the\n// 3/4 downward view and aren't occluded by the front lip. +x ear at x3..4;\n// mirrors to a wide-spaced symmetric pair. 2-wide base -> 1 mid -> pointy tip.\nbox([3, -3, 17], [4, -2, 17], ORG);         // ear base (2 wide x 2 deep)\nv.set(4, -3, 17, ORG_D);                     // outer base shadow\nv.set(3, -2, 17, PINK);                      // inner-ear pink\nbox([3, -3, 18], [3, -2, 18], ORG);         // ear mid (1 wide)\nv.set(3, -3, 19, ORG_L);                     // pointy tip\n\n// ============ TAIL (curls up beside the body) ============\nbox([5, 2, 0], [5, 4, 1], ORG_D);           // tail root at back-side base\nbox([5, 2, 2], [5, 4, 7], ORG);             // tail rises up the side\nbox([5, 0, 7], [5, 3, 8], ORG_L);           // top of curl bends forward\nbox([5, -2, 8], [5, 1, 8], ORG_L);          // tip sweeps to the front\nv.set(5, -2, 8, WHT);                        // white tail tip\nv.set(5, 3, 3, STR); v.set(5, 2, 5, STR);   // tabby rings\n\n// mirror across x to complete the symmetric cat\nv.mirror('x');\n\nreturn v;\n",
