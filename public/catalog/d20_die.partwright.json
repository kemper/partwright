      "index": 1,
      "code": "const { Manifold, label } = api;\n\n// ---- Icosahedron via hull (the d20 identity) -------------------------------\n// 12 vertices = cyclic permutations of (0, +/-1, +/-phi), phi = golden ratio.\nconst phi = (1 + Math.sqrt(5)) / 2;\nconst scale = 9; // circumradius\nconst rawVerts = [\n  [0, 1, phi],\n  [0, -1, phi],\n  [0, 1, -phi],\n  [0, -1, -phi],\n  [1, phi, 0],\n  [-1, phi, 0],\n  [1, -phi, 0],\n  [-1, -phi, 0],\n  [phi, 0, 1],\n  [-phi, 0, 1],\n  [phi, 0, -1],\n  [-phi, 0, -1],\n];\nconst len = Math.sqrt(1 + phi * phi);\nconst verts = rawVerts.map(([x, y, z]) => [x / len * scale, y / len * scale, z / len * scale]);\n\n// Hull of small spheres at each vertex = a clean icosahedron, then rotate so\n// one triangular face is flat-up (+Z). Face 0's normal is [0.357, 0, 0.934];\n// a -20.905 deg turn about Y brings that normal to +Z, putting the face on top.\nconst spheres = verts.map(v => Manifold.sphere(0.5, 4).translate(v));\nconst TILT = -20.905157447889305;\nconst body = label(Manifold.hull(spheres).rotate([0, TILT, 0]), 'body');\n\n// ---- Raised gold \"20\" on the flat top face ---------------------------------\n// The top face is now a horizontal equilateral triangle at z = 7.1519\n// (circumradius ~5.46), its lone vertex pointing toward +X.\nconst FACE_Z = 7.151890250625896;\nconst RAISE = 0.7; // numeral height standing proud of the face\nconst SINK = 0.5; // overlap down into the solid body so numerals fuse\n\n// 7-segment digit cell, local coords: u = across, v = up the face. Solid bars\n// make bold, thumbnail-legible glyphs.\nconst Wc = 2.0,\n  Hc = 3.2,\n  s = 0.62,\n  half = s / 2;\nconst SEG = {\n  A: [0, Hc - s, Wc, Hc], // top\n  G: [0, Hc / 2 - half, Wc, Hc / 2 + half], // middle\n  D: [0, 0, Wc, s], // bottom\n  F: [0, Hc / 2, s, Hc], // top-left\n  B: [Wc - s, Hc / 2, Wc, Hc], // top-right\n  E: [0, 0, s, Hc / 2], // bottom-left\n  C: [Wc - s, 0, Wc, Hc / 2], // bottom-right\n};\nconst DIGITS = {\n  '2': ['A', 'B', 'G', 'E', 'D'],\n  '0': ['A', 'B', 'C', 'D', 'E', 'F'],\n};\n\n// One digit = union of bar cubes; map local (u -> world Y, v -> world X).\nfunction makeDigit(ch, xOff, yOff) {\n  const bars = DIGITS[ch].map(name => {\n    const [u0, v0, u1, v1] = SEG[name];\n    return Manifold.cube([v1 - v0, u1 - u0, RAISE + SINK], false)\n      .translate([v0 + xOff, u0 + yOff, FACE_Z - SINK]);\n  });\n  return Manifold.union(bars);\n}\n\nconst gap = 0.85;\nconst blockW = 2 * Wc + gap; // total \"20\" width along Y\nconst yStart = -blockW / 2; // center the pair on Y = 0\nconst xOff = -0.4 - Hc / 2; // bias the height band toward the wide side\nconst two = makeDigit('2', xOff, yStart);\nconst zero = makeDigit('0', xOff, yStart + Wc + gap);\n// The (v->X, u->Y) digit mapping renders the glyphs mirrored (a backwards \"2\"\n// reads like an \"S\"). Mirror across the XZ plane (flip Y) to un-mirror the\n// chirality so \"20\" reads correctly; azimuth then orders the digits.\nconst numerals = label(two.add(zero).mirror([0, 1, 0]), 'numerals');\n\nreturn body.add(numerals);\n",
