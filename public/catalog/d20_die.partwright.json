      "index": 1,
      "code": "const { Manifold, label } = api;\n\n// ============================================================================\n// D20 — icosahedral die with an engraved number inset on ALL 20 faces.\n// ============================================================================\n\n// ---- 1. Icosahedron geometry ----------------------------------------------\nconst phi = (1 + Math.sqrt(5)) / 2;\nconst R = 9; // target circumradius\nconst rawVerts = [\n  [0, 1, phi],\n  [0, -1, phi],\n  [0, 1, -phi],\n  [0, -1, -phi],\n  [1, phi, 0],\n  [-1, phi, 0],\n  [1, -phi, 0],\n  [-1, -phi, 0],\n  [phi, 0, 1],\n  [-phi, 0, 1],\n  [phi, 0, -1],\n  [-phi, 0, -1],\n];\nconst sc = R / Math.sqrt(1 + phi * phi);\nconst V = rawVerts.map(([x, y, z]) => [x * sc, y * sc, z * sc]);\n\nconst body = Manifold.hull(V.map((v) => Manifold.sphere(0.35, 4).translate(v)));\n\n// ---- vector / matrix helpers ----------------------------------------------\nconst sub = (a, b) => [a[0] - b[0], a[1] - b[1], a[2] - b[2]];\nconst dot = (a, b) => a[0] * b[0] + a[1] * b[1] + a[2] * b[2];\nconst cross = (a, b) => [\n  a[1] * b[2] - a[2] * b[1],\n  a[2] * b[0] - a[0] * b[2],\n  a[0] * b[1] - a[1] * b[0],\n];\nconst norm = (a) => { const m = Math.hypot(a[0], a[1], a[2]); return [a[0] / m, a[1] / m, a[2] / m]; };\nconst RAD = 180 / Math.PI;\nconst rotY = (t) => [\n  [Math.cos(t), 0, Math.sin(t)],\n  [0, 1, 0],\n  [-Math.sin(t), 0, Math.cos(t)]\n];\nconst rotZ = (t) => [\n  [Math.cos(t), -Math.sin(t), 0],\n  [Math.sin(t), Math.cos(t), 0],\n  [0, 0, 1]\n];\nconst mv = (M, v) => [\n  M[0][0] * v[0] + M[0][1] * v[1] + M[0][2] * v[2],\n  M[1][0] * v[0] + M[1][1] * v[1] + M[1][2] * v[2],\n  M[2][0] * v[0] + M[2][1] * v[1] + M[2][2] * v[2],\n];\n\n// ---- 2. Enumerate the 20 faces --------------------------------------------\nconst dist = (a, b) => Math.hypot(a[0] - b[0], a[1] - b[1], a[2] - b[2]);\nlet edge = Infinity;\nfor (let i = 0; i < 12; i++)\n  for (let j = i + 1; j < 12; j++) edge = Math.min(edge, dist(V[i], V[j]));\nconst isEdge = (a, b) => Math.abs(dist(V[a], V[b]) - edge) < 1e-6 * R;\n\nconst faces = [];\nfor (let a = 0; a < 12; a++)\n  for (let b = a + 1; b < 12; b++)\n    for (let c = b + 1; c < 12; c++)\n      if (isEdge(a, b) && isEdge(b, c) && isEdge(a, c)) faces.push([a, b, c]);\n\nfunction faceInfo(tri) {\n  const c = [0, 0, 0];\n  for (const idx of tri)\n    for (let k = 0; k < 3; k++) c[k] += V[idx][k] / 3;\n  const n = norm(c);\n  let ref = [0, 0, 1];\n  let up = sub(ref, [n[0] * dot(ref, n), n[1] * dot(ref, n), n[2] * dot(ref, n)]);\n  if (Math.hypot(up[0], up[1], up[2]) < 1e-3) {\n    ref = [0, 1, 0];\n    up = sub(ref, [n[0] * dot(ref, n), n[1] * dot(ref, n), n[2] * dot(ref, n)]);\n  }\n  up = norm(up);\n  return { centroid: c, normal: n, up };\n}\nconst info = faces.map(faceInfo);\n\n// ---- 3. Flat numeral builder (bold 7-segment bars) ------------------------\nconst Wc = 1.55,\n  Hc = 2.5,\n  t = 0.5;\nconst DEPTH = 1.2;\nconst ENGRAVE = 0.55;\nconst SEG = {\n  A: [0, Hc - t, Wc, Hc],\n  G: [0, Hc / 2 - t / 2, Wc, Hc / 2 + t / 2],\n  D: [0, 0, Wc, t],\n  F: [0, Hc / 2, t, Hc],\n  B: [Wc - t, Hc / 2, Wc, Hc],\n  E: [0, 0, t, Hc / 2],\n  C: [Wc - t, 0, Wc, Hc / 2],\n};\nconst DIGITS = {\n  '0': ['A', 'B', 'C', 'D', 'E', 'F'],\n  '1': ['B', 'C'],\n  '2': ['A', 'B', 'G', 'E', 'D'],\n  '3': ['A', 'B', 'G', 'C', 'D'],\n  '4': ['F', 'G', 'B', 'C'],\n  '5': ['A', 'F', 'G', 'C', 'D'],\n  '6': ['A', 'F', 'G', 'E', 'C', 'D'],\n  '7': ['A', 'B', 'C'],\n  '8': ['A', 'B', 'C', 'D', 'E', 'F', 'G'],\n  '9': ['A', 'B', 'C', 'D', 'F', 'G'],\n};\n\nfunction digit(ch) {\n  const bars = DIGITS[ch].map((name) => {\n    const [x0, y0, x1, y1] = SEG[name];\n    return Manifold.cube([x1 - x0, y1 - y0, DEPTH], false).translate([x0, y0, 0]);\n  });\n  return Manifold.union(bars).translate([-Wc / 2, -Hc / 2, 0]);\n}\n\nfunction numberGlyph(str) {\n  const gap = 0.45;\n  const totalW = str.length * Wc + (str.length - 1) * gap;\n  let x = -totalW / 2 + Wc / 2;\n  const parts = [];\n  for (const ch of str) {\n    parts.push(digit(ch).translate([x, 0, 0]));\n    x += Wc + gap;\n  }\n  return Manifold.union(parts);\n}\n\n// ---- 4. Orient a flat (+Z) glyph onto a face & choose upright spin ---------\nfunction buildOriented(flat, fi) {\n  const n = fi.normal;\n  const theta = Math.acos(Math.max(-1, Math.min(1, n[2])));\n  const azim = Math.atan2(n[1], n[0]);\n  const base = (v) => mv(rotZ(azim), mv(rotY(theta), v));\n  const baseUp = base([0, 1, 0]);\n  const cosA = Math.max(-1, Math.min(1, dot(baseUp, fi.up)));\n  let spin = Math.acos(cosA);\n  if (dot(cross(baseUp, fi.up), n) < 0) spin = -spin;\n  return flat\n    .rotate([0, 0, spin * RAD])\n    .rotate([0, theta * RAD, 0])\n    .rotate([0, 0, azim * RAD]);\n}\n\n// ---- 5. Standard d20 numbering (opposite faces sum to 21) ------------------\nconst used = new Array(20).fill(false);\nconst faceNumber = new Array(20).fill(0);\nlet k = 1;\nfor (let i = 0; i < 20; i++) {\n  if (used[i]) continue;\n  let opp = -1;\n  for (let j = 0; j < 20; j++) {\n    if (j === i || used[j]) continue;\n    if (dot(info[i].normal, info[j].normal) < -0.999) { opp = j; break; }\n  }\n  used[i] = true;\n  faceNumber[i] = k;\n  if (opp >= 0) { used[opp] = true;\n    faceNumber[opp] = 21 - k; }\n  k++;\n}\n\n// ---- 6. Build & subtract all 20 engraving cutters -------------------------\nconst cutters = [];\nfor (let i = 0; i < 20; i++) {\n  const fi = info[i];\n  const flat = numberGlyph(String(faceNumber[i])).translate([0, 0, -ENGRAVE]);\n  const oriented = buildOriented(flat, fi);\n  cutters.push(oriented.translate(fi.centroid));\n}\n\nconst engraved = body.subtract(Manifold.union(cutters));\nreturn label(engraved, 'body');\n",
